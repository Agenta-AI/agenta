# AGENTA_AI_SERVICES_ENVIRONMENT_SLUG=
# AGENTA_AI_SERVICES_REFINE_PROMPT_KEY=

# ================================================================== #
# Agenta - Agent runner
# ================================================================== #
# All agent-runner configuration lives here. Nothing below this section configures the runner.
# In particular the bare DAYTONA_* block is the CODE EVALUATOR's sandbox, not the agent runner.

# --- Service ---
# Bind interface. The code default is 127.0.0.1; compose sets 0.0.0.0 so the api can reach it.
# AGENTA_RUNNER_HOST=0.0.0.0
# Bind port.
# AGENTA_RUNNER_PORT=8765
# Maximum concurrent runs.
# AGENTA_RUNNER_CONCURRENCY_LIMIT=1000
# Runner log verbosity.
# AGENTA_RUNNER_LOG_LEVEL=silent
# Replica identity for logs. Generated when unset.
# AGENTA_RUNNER_REPLICA_ID=

# --- Routing and auth ---
# Caller-side: where the api/services side reaches the runner.
# AGENTA_RUNNER_INTERNAL_URL=http://runner:8765
# SECRET. Shared request credential. Set the SAME value on the api/services side and on the
# runner to require auth. Unset (the default) disables the check.
# AGENTA_RUNNER_TOKEN=
# Caller-side: idle timeout (seconds) the api/services SDK allows on the streaming run request.
# The runner does not read it. The runner's own deadlines are under "Run limits" below.
# AGENTA_RUNNER_TIMEOUT_SECONDS=180

# --- Sandbox providers (read by BOTH the api/services side and the runner) ---
# Comma-separated provider ids. Known ids are `local` and `daytona`. Unset means `local`.
# Set to `local,daytona` to also enable the Daytona provider configured below.
# AGENTA_RUNNER_ENABLED_SANDBOX_PROVIDERS=local
# The provider a run gets when it does not choose. Must be one of the enabled ids.
# AGENTA_RUNNER_DEFAULT_SANDBOX_PROVIDER=local

# --- Daytona (the AGENT RUNNER's own sandbox; NOT the code evaluator) ---
# Required only when `daytona` is in AGENTA_RUNNER_ENABLED_SANDBOX_PROVIDERS.
# The api key, api url, and target below may point at the SAME Daytona account as the code
# evaluator's DAYTONA_* block. The SNAPSHOT MUST NOT BE SHARED: the evaluator's snapshot (for
# example `daytona-small`) carries no agent harness, so an agent booted into it cannot run.
# The agent runner needs its own snapshot, built by
# services/runner/images/sandbox/daytona/build_snapshot.py.
# SECRET. Provisioning credential.
# AGENTA_RUNNER_DAYTONA_API_KEY=
# AGENTA_RUNNER_DAYTONA_API_URL=https://app.daytona.io/api
# Region or target.
# AGENTA_RUNNER_DAYTONA_TARGET=eu
# Empty means the runner's pinned default snapshot, `agenta-agent-sandbox-v1`. Never set this
# to the code evaluator's DAYTONA_SNAPSHOT.
# AGENTA_RUNNER_DAYTONA_SNAPSHOT=
# Mutually exclusive with AGENTA_RUNNER_DAYTONA_SNAPSHOT.
# AGENTA_RUNNER_DAYTONA_IMAGE=
# Idle minutes before a sandbox is stopped (its disk is kept).
# AGENTA_RUNNER_DAYTONA_AUTOSTOP_MINUTES=15
# Idle minutes before a stopped sandbox is deleted.
# AGENTA_RUNNER_DAYTONA_AUTODELETE_MINUTES=30

# --- Warm sessions and scale ---
# Daytona warm pool, between turns. HARD CONSTRAINT: keep the idle TTL below
# AGENTA_RUNNER_DAYTONA_AUTOSTOP_MINUTES, or Daytona stops a sandbox the runner still believes
# is warm, and the next turn pays a cold start anyway.
# How long an idle sandbox stays running between turns. 0 stops it after each turn.
# AGENTA_RUNNER_DAYTONA_SESSION_IDLE_TTL_MS=120000
# Maximum idle sandboxes kept running. Overflow parks in the stopped state.
# AGENTA_RUNNER_DAYTONA_SESSION_MAX_WARM=20
# Local in-container session pool. Read for the `local` provider only; Daytona ignores these.
# Maximum pooled local sessions.
# AGENTA_RUNNER_SESSION_POOL_MAX=8
# Idle lifetime of a pooled local session.
# AGENTA_RUNNER_SESSION_TTL_MS=60000
# Idle lifetime while a run waits for a human approval.
# AGENTA_RUNNER_SESSION_APPROVAL_TTL_MS=300000
# Local session reuse is ON by default. Set to `off` to make every local turn take the cold path.
# AGENTA_RUNNER_SESSION_KEEPALIVE=

# --- Run limits (per run; cost and wedge protection) ---
# A run paused for a human approval is exempt from all four.
# 45 min. Hard deadline for one run.
# AGENTA_RUNNER_RUN_TOTAL_TIMEOUT_MS=2700000
# 5 min. No progress event for this long aborts the run. Must stay below the total deadline.
# AGENTA_RUNNER_RUN_IDLE_TIMEOUT_MS=300000
# 2 min. No first response this long after the run starts aborts it.
# AGENTA_RUNNER_RUN_TTFB_TIMEOUT_MS=120000
# 5 min. One tool call exceeding this aborts the run.
# AGENTA_RUNNER_TOOL_CALL_TIMEOUT_MS=300000

# ================================================================== #
# Agenta - API
# ================================================================== #
# AGENTA_API_CACHING_ENABLED=true

# ================================================================== #
# Agenta - Extras
# ================================================================== #
# AGENTA_EXTRAS_DEMOS=

# ================================================================== #
# Agenta - Logging
# ================================================================== #
# AGENTA_LOGGING_CONSOLE_ENABLED=true
# AGENTA_LOGGING_CONSOLE_LEVEL=TRACE
# AGENTA_LOGGING_FILE_ENABLED=true
# AGENTA_LOGGING_FILE_LEVEL=WARNING
# AGENTA_LOGGING_FILE_PATH=error
# AGENTA_LOGGING_OTLP_ENABLED=false
# AGENTA_LOGGING_OTLP_LEVEL=INFO

# ================================================================== #
# Agenta - OTLP
# ================================================================== #
# AGENTA_OTLP_MAX_BATCH_BYTES=10485760

# ================================================================== #
# Agenta - Redaction (online redaction filter, Slice 1 known-value pass)
# ================================================================== #
# AGENTA_REDACTION_MODE=known
# Name matchers (comma-separated), each MERGES onto its built-in default:
# AGENTA_REDACTED_PREFIXES=
# AGENTA_REDACTED_SUFFIXES=
# AGENTA_REDACTED_BLOCKLIST=
# Literal values never redacted (merges onto the default booleans/flags):
# AGENTA_REDACTED_ALLOWLIST=

# ================================================================== #
# Agenta - Services (code/hook/middleware)
# ================================================================== #
# Custom-code evaluator runner: local (default, no sandbox, raw exec — trusted/
# single-tenant only) | restricted (in-process sandbox) | daytona (isolated remote sandbox)
# AGENTA_SERVICES_CODE_SANDBOX_RUNNER=local
# AGENTA_SERVICES_MIDDLEWARE_AUTH_ENABLED=true
# AGENTA_SERVICES_MIDDLEWARE_CACHING_ENABLED=true

# ================================================================== #
# Agenta - Egress (SSRF protection)
# ================================================================== #
# AGENTA_INSECURE_EGRESS_ALLOWED=true

