# SMTP_PORT=1025
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_TIMEOUT=10

