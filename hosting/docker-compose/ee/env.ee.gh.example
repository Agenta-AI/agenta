# ================================================================== #
# Agenta - License (https://agenta.ai/pricing)
# ================================================================== #
AGENTA_LICENSE=ee

# ================================================================== #
# Agenta - Docker images
# ================================================================== #
# AGENTA_WEB_IMAGE_NAME=agenta-web
# AGENTA_WEB_IMAGE_TAG=latest
# AGENTA_API_IMAGE_NAME=agenta-api
# AGENTA_API_IMAGE_TAG=latest
# AGENTA_SERVICES_IMAGE_NAME=agenta-services
# AGENTA_SERVICES_IMAGE_TAG=latest
# AGENTA_RUNNER_IMAGE_NAME=internal-ee-agenta-runner
# AGENTA_RUNNER_IMAGE_TAG=latest

# ================================================================== #
# Agenta - Core endpoints
# ================================================================== #
AGENTA_WEB_URL=http://localhost
AGENTA_SERVICES_URL=http://localhost/services
AGENTA_API_URL=http://localhost/api
# AGENTA_API_INTERNAL_URL=http://api:8000
# AGENTA_RUNNER_INTERNAL_URL=http://runner:8765

# ================================================================== #
# Agenta - Secrets (REPLACE in production!)
# ================================================================== #
AGENTA_AUTH_KEY=replace-me
AGENTA_CRYPT_KEY=replace-me

# ================================================================== #
# Agenta - Access controls
# ================================================================== #
# AGENTA_ACCESS_ALLOWED_DOMAINS=
# AGENTA_ACCESS_ALLOWED_OWNER_EMAILS=
# AGENTA_ACCESS_BLOCKED_DOMAINS=
# AGENTA_ACCESS_BLOCKED_EMAILS=
# AGENTA_ACCESS_DEFAULT_PLAN=
# AGENTA_ACCESS_DEFAULT_PLAN_OVERLAY=
# AGENTA_ACCESS_EMAIL_DISABLED=false
# AGENTA_ACCESS_PLANS=
# AGENTA_ACCESS_ROLES=
# AGENTA_ACCESS_ROLES_OVERLAY=

# ================================================================== #
# Agenta - AI services
# ================================================================== #
# AGENTA_AI_SERVICES_API_KEY=
# AGENTA_AI_SERVICES_API_URL=
# AGENTA_AI_SERVICES_ENVIRONMENT_SLUG=
# AGENTA_AI_SERVICES_REFINE_PROMPT_KEY=

# ================================================================== #
# Agenta - Agent
# ================================================================== #
# AGENTA_RUNNER_HOST=0.0.0.0
# AGENTA_API_KEY=
# AGENTA_AGENT_SANDBOX_PI_DIR=/home/sandbox/.pi/agent
# AGENTA_AGENT_SANDBOX_PI_VERSION=0.80.6
# AGENTA_AGENT_SANDBOX_PI_INSTALLED=true

# ================================================================== #
# Agenta - API
# ================================================================== #
# AGENTA_API_CACHING_ENABLED=true

# ================================================================== #
# Agenta - Extras
# ================================================================== #
# AGENTA_EXTRAS_DEMOS=

# ================================================================== #
# Agenta - Logging
# ================================================================== #
# AGENTA_LOGGING_CONSOLE_ENABLED=true
# AGENTA_LOGGING_CONSOLE_LEVEL=TRACE
# AGENTA_LOGGING_FILE_ENABLED=true
# AGENTA_LOGGING_FILE_LEVEL=WARNING
# AGENTA_LOGGING_FILE_PATH=error
# AGENTA_LOGGING_OTLP_ENABLED=false
# AGENTA_LOGGING_OTLP_LEVEL=INFO

# ================================================================== #
# Agenta - OTLP
# ================================================================== #
# AGENTA_OTLP_MAX_BATCH_BYTES=10485760

# ================================================================== #
# Agenta - Redaction (online redaction filter, Slice 1 known-value pass)
# ================================================================== #
# AGENTA_REDACTION_MODE=known
# Name matchers (comma-separated), each MERGES onto its built-in default:
# AGENTA_REDACTED_PREFIXES=
# AGENTA_REDACTED_SUFFIXES=
# AGENTA_REDACTED_BLOCKLIST=
# Literal values never redacted (merges onto the default booleans/flags):
# AGENTA_REDACTED_ALLOWLIST=

# ================================================================== #
# Agenta - Services (code/hook/middleware)
# ================================================================== #
# Custom-code evaluator runner: local (default, no sandbox, raw exec — trusted/
# single-tenant only) | restricted (in-process sandbox) | daytona (isolated remote sandbox)
# AGENTA_SERVICES_CODE_SANDBOX_RUNNER=local
# AGENTA_SERVICES_MIDDLEWARE_AUTH_ENABLED=true
# AGENTA_SERVICES_MIDDLEWARE_CACHING_ENABLED=true

# ================================================================== #
# Agenta - Egress (SSRF protection)
# ================================================================== #
# AGENTA_INSECURE_EGRESS_ALLOWED=true

# ================================================================== #
# Agenta - Sandbox (agent runner)
# ================================================================== #
# `local` sandbox runs unconfined host bash; default true, set to false to harden a
# shared/multi-tenant deployment.
# AGENTA_SANDBOX_LOCAL_ALLOWED=true

# ================================================================== #
# alembic
# ================================================================== #
# ALEMBIC_AUTO_MIGRATIONS=true
# ALEMBIC_CFG_PATH_CORE=/app/ee/databases/postgres/migrations/core/alembic.ini
# ALEMBIC_CFG_PATH_TRACING=/app/ee/databases/postgres/migrations/tracing/alembic.ini

# ================================================================== #
# cloudflare
# ================================================================== #
# CLOUDFLARE_TURNSTILE_ALLOWED_HOSTNAMES=
# CLOUDFLARE_TURNSTILE_SECRET_KEY=
# CLOUDFLARE_TURNSTILE_SITE_KEY=

# ================================================================== #
# composio
# ================================================================== #
# COMPOSIO_API_KEY=
# COMPOSIO_API_URL=https://backend.composio.dev/api/v3

# ================================================================== #
# crisp
# ================================================================== #
# CRISP_WEBSITE_ID=

# ================================================================== #
# daytona
# ================================================================== #
# DAYTONA_API_KEY=
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_TARGET=eu
# DAYTONA_SNAPSHOT=
# DAYTONA_SNAPSHOT_CODE=
# DAYTONA_SNAPSHOT_AGENT=
# DAYTONA_IMAGE=
# DAYTONA_AUTOSTOP=15  # idle minutes before a sandbox is stopped (disk kept)
# DAYTONA_AUTODELETE=30  # idle minutes before a stopped sandbox is deleted
# AGENTA_RUNNER_DAYTONA_SESSION_IDLE_TTL_MS=  # milliseconds to keep an idle session running between turns
# AGENTA_RUNNER_DAYTONA_SESSION_MAX_WARM=  # maximum idle sessions that may stay running between turns

# ================================================================== #
# docker
# ================================================================== #
# DOCKER_NETWORK_MODE=bridge  # compose defaults to "bridge" via ${DOCKER_NETWORK_MODE:-bridge}; uncomment only to override (e.g. "host")

