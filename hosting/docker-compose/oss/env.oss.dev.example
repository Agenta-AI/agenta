# ================================================================== #
# Agenta - License (https://agenta.ai/pricing)
# ================================================================== #
AGENTA_LICENSE=oss

# ================================================================== #
# Agenta - Docker images
# ================================================================== #
# AGENTA_WEB_IMAGE_NAME=agenta-web
# AGENTA_WEB_IMAGE_TAG=latest
# AGENTA_API_IMAGE_NAME=agenta-api
# AGENTA_API_IMAGE_TAG=latest
# AGENTA_SERVICES_IMAGE_NAME=agenta-services
# AGENTA_SERVICES_IMAGE_TAG=latest

# ================================================================== #
# Agenta - Core endpoints
# ================================================================== #
AGENTA_WEB_URL=http://localhost
AGENTA_SERVICES_URL=http://localhost/services
AGENTA_API_URL=http://localhost/api
# AGENTA_API_INTERNAL_URL=

# ================================================================== #
# Agenta - Secrets (REPLACE in production!)
# ================================================================== #
AGENTA_AUTH_KEY=replace-me
AGENTA_CRYPT_KEY=replace-me

# ================================================================== #
# Agenta - Access controls
# ================================================================== #
# AGENTA_ACCESS_ALLOWED_DOMAINS=
# AGENTA_ACCESS_ALLOWED_OWNER_EMAILS=
# AGENTA_ACCESS_BLOCKED_DOMAINS=
# AGENTA_ACCESS_BLOCKED_EMAILS=
# AGENTA_ACCESS_DEFAULT_PLAN=
# AGENTA_ACCESS_DEFAULT_PLAN_OVERLAY=
# AGENTA_ACCESS_EMAIL_DISABLED=false
# AGENTA_ACCESS_PLANS=
# AGENTA_ACCESS_ROLES=
# AGENTA_ACCESS_ROLES_OVERLAY=

# ================================================================== #
# Agenta - AI services
# ================================================================== #
# AGENTA_AI_SERVICES_API_KEY=
# AGENTA_AI_SERVICES_API_URL=
# AGENTA_AI_SERVICES_ENVIRONMENT_SLUG=
# AGENTA_AI_SERVICES_REFINE_PROMPT_KEY=

# ================================================================== #
# Agenta - API
# ================================================================== #
# AGENTA_API_CACHING_ENABLED=true

# ================================================================== #
# Agenta - Extras
# ================================================================== #
# AGENTA_EXTRAS_DEMOS=

# ================================================================== #
# Agenta - Logging
# ================================================================== #
# AGENTA_LOGGING_CONSOLE_ENABLED=true
# AGENTA_LOGGING_CONSOLE_LEVEL=TRACE
# AGENTA_LOGGING_FILE_ENABLED=true
# AGENTA_LOGGING_FILE_LEVEL=WARNING
# AGENTA_LOGGING_FILE_PATH=error
# AGENTA_LOGGING_OTLP_ENABLED=false
# AGENTA_LOGGING_OTLP_LEVEL=INFO

# ================================================================== #
# Agenta - OTLP
# ================================================================== #
# AGENTA_OTLP_MAX_BATCH_BYTES=10485760

# ================================================================== #
# Agenta - Services (code/hook/middleware)
# ================================================================== #
# AGENTA_SERVICES_CODE_SANDBOX_RUNNER=local
# AGENTA_SERVICES_HOOK_ALLOW_INSECURE=true
# AGENTA_SERVICES_MIDDLEWARE_AUTH_ENABLED=true
# AGENTA_SERVICES_MIDDLEWARE_CACHING_ENABLED=true

# ================================================================== #
# Agenta - Webhooks
# ================================================================== #
# AGENTA_WEBHOOKS_ALLOW_INSECURE=true

