{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "webUrl": { "type": "string" },
        "apiUrl": { "type": "string" },
        "servicesUrl": { "type": "string" },
        "imagePullSecrets": { "type": "array" }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "existingSecret": { "type": "string" },
        "agentaAuthKey": { "type": "string" },
        "agentaCryptKey": { "type": "string" },
        "postgresPassword": { "type": "string" },
        "supertokensApiKey": { "type": "string" },
        "oauth": { "type": "object" },
        "llmProviders": { "type": "object" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "auth": {
          "type": "object",
          "properties": {
            "username": { "type": "string" }
          }
        },
        "databases": {
          "type": "object",
          "properties": {
            "core": { "type": "string" },
            "tracing": { "type": "string" },
            "supertokens": { "type": "string" }
          }
        },
        "external": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "username": { "type": "string" },
            "sslmode": {
              "type": "string",
              "enum": ["", "disable", "allow", "prefer", "require", "verify-ca", "verify-full"],
              "description": "SSL mode for external PostgreSQL connections. Appended to auto-constructed URIs only (ignored when full URI overrides are set). Set to empty string to omit."
            },
            "uriCore": { "type": "string" },
            "uriTracing": { "type": "string" },
            "uriSupertokens": { "type": "string" }
          }
        }
      }
    },
    "redisVolatile": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "$ref": "#/$defs/image" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "password": { "type": "string" },
        "maxmemory": { "type": "string", "pattern": "^[0-9]+([kKmMgG][bB])?$" },
        "maxmemoryPolicy": {
          "type": "string",
          "enum": ["volatile-lru", "volatile-lfu", "volatile-random", "volatile-ttl", "allkeys-lru", "allkeys-lfu", "allkeys-random", "noeviction"]
        },
        "external": {
          "type": "object",
          "properties": {
            "uri": { "type": "string" }
          }
        }
      }
    },
    "redisDurable": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "$ref": "#/$defs/image" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "password": { "type": "string" },
        "maxmemory": { "type": "string", "pattern": "^[0-9]+([kKmMgG][bB])?$" },
        "maxmemoryPolicy": {
          "type": "string",
          "enum": ["volatile-lru", "volatile-lfu", "volatile-random", "volatile-ttl", "allkeys-lru", "allkeys-lfu", "allkeys-random", "noeviction"]
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "size": { "type": "string" },
            "storageClass": { "type": "string" }
          }
        },
        "external": {
          "type": "object",
          "properties": {
            "uri": { "type": "string" }
          }
        }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "$ref": "#/$defs/image" },
        "replicas": { "type": "integer", "minimum": 0 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "workers": { "type": "integer", "minimum": 1 },
        "env": { "type": "object" },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "web": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "$ref": "#/$defs/image" },
        "replicas": { "type": "integer", "minimum": 0 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "env": { "type": "object" },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "services": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "$ref": "#/$defs/image" },
        "replicas": { "type": "integer", "minimum": 0 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "workers": { "type": "integer", "minimum": 1 },
        "env": { "type": "object" },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "workerEvaluations": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "env": { "type": "object" },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "workerTracing": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "env": { "type": "object" },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "cron": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "env": { "type": "object" },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "alembic": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 1 },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
        "env": { "type": "object" },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "supertokens": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "$ref": "#/$defs/image" },
        "replicas": { "type": "integer", "minimum": 0 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "env": { "type": "object" },
        "resources": { "$ref": "#/$defs/resources" },
        "external": {
          "type": "object",
          "properties": {
            "uri": { "type": "string" }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "host": { "type": "string" },
        "tls": { "type": "array" },
        "annotations": { "type": "object" },
        "paths": {
          "type": "object",
          "description": "Ingress path configuration per backend. Override paths and pathType for different ingress controllers (e.g. regex capture groups for NGINX).",
          "properties": {
            "api": { "$ref": "#/$defs/ingressPath" },
            "services": { "$ref": "#/$defs/ingressPath" },
            "web": { "$ref": "#/$defs/ingressPath" }
          }
        }
      }
    },
    "extraObjects": {
      "type": "array"
    }
  },
  "$defs": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "ingressPath": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "description": "URL path pattern for this backend." },
        "pathType": {
          "type": "string",
          "enum": ["Prefix", "Exact", "ImplementationSpecific"],
          "description": "Kubernetes pathType. Use ImplementationSpecific with regex paths for NGINX."
        }
      },
      "required": ["path", "pathType"]
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?([eE][0-9]+)?([EPTGMK]i?)?$" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?([eE][0-9]+)?([EPTGMK]i?)?$" }
          }
        }
      }
    }
  }
}
