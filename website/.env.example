# Agenta marketing site — public, build-time environment variables.
#
# Copy this file to `.env` and fill in real values for a production build.
# Only PUBLIC_* vars are exposed to the browser (Astro/Vite convention), which is
# correct here: both keys below are public, client-side analytics ids.
# `.env` is gitignored — never commit real keys.

# PostHog project API key (public, client-side). Loaded through our own reverse
# proxy at https://alef.agenta.ai (same setup as the docs site). When unset, the
# PostHog snippet is omitted entirely, so local dev / forks never emit events.
PUBLIC_POSTHOG_KEY=

# Google Analytics 4 measurement id. Default: G-368ZWZSH5D (this site's own GA4
# property). Set to a different id to override, or set to empty string to disable.
# Do NOT reuse the docs' GTM container (G-LTF78FZS33). See Base.astro.
PUBLIC_GA_ID=G-368ZWZSH5D

# Noindex flag for test/preview deploys. When set to "true":
#   - Emits <meta name="robots" content="noindex, nofollow"> on every page (Base.astro).
#   - Serves a disallow-all robots.txt (src/pages/robots.txt.ts).
# Default (unset or any other value) = normal indexable production behavior.
# Set this in your preview deploy environment; never set it for the live site.
PUBLIC_NOINDEX=
