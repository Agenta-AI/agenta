---
// Site — the shared page layout for the marketing site.
//
// Wraps Base (html/head: fonts, tokens, global CSS, meta/OG + a `head` slot) and
// renders the shared chrome around the page body: SiteNav, the page <slot/>, an
// optional yellow CTA band, and SiteFooter — all inside the 1440-wide frame that
// shows the page background as a 12px gutter (same as the landing).
//
// Chrome is unified with the landing: the same SiteNav (hover dropdowns, button
// hover) and SiteFooter render everywhere. SiteNav is passed WITHOUT `sticky`
// here, so inner pages get a static top bar; only the landing sticks + pills.
import Base from "./Base.astro";
import SiteNav from "../components/SiteNav.astro";
import CtaBand from "../components/CtaBand.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface CtaProps {
  title?: string;
  body?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

interface Props {
  title?: string;
  description?: string;
  // og:type and og:image, passed straight through to Base for the head meta.
  // Blog posts set ogType="article" and an ogImage; everything else defaults.
  ogType?: "website" | "article";
  ogImage?: string;
  // Show the shared yellow CTA band before the footer (default: true).
  showCta?: boolean;
  // Optional copy/destinations for the CTA band; omitted keys fall back to the
  // landing defaults baked into CtaBand.astro.
  cta?: CtaProps;
}

const {
  title,
  description,
  ogType,
  ogImage,
  showCta = true,
  cta = {},
} = Astro.props;
---

<Base title={title} description={description} ogType={ogType} ogImage={ogImage}>
  <slot name="head" slot="head" />

  <!-- The page bg shows as a 12px frame around the 1440-wide section stack. -->
  <div
    class="ag-wrap"
    style="width:100%;max-width:1440px;margin:0 auto;background:#0A0A0B;padding:0 12px;box-sizing:border-box;font-family:var(--font-sans);"
  >
    <SiteNav />
    <main>
      <slot />
    </main>
    {showCta && <CtaBand {...cta} />}
    <SiteFooter />
  </div>
</Base>
