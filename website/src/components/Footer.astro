---
// Footer — shared dark footer. Links match the LIVE agenta.ai site exactly (see
// docs/design/marketing-website/research/live-url-link-map.md).
//   - Product links go to agenta.ai/docs/... (there are NO /product/* pages).
//   - Resources/Legal go to the live docs URLs; Legal Terms+Privacy point to
//     docs (NOT to /terms or /privacy-policy, which redirect to termly).
//   - Footer social Slack uses the FOOTER invite token (zt-2yewk6o2b); the nav
//     Community dropdown uses a DIFFERENT token (zt-37pnbp5s6).
//   - Contact keeps pointing to our own /contact page (user override; live uses
//     /imprint, but we keep our contact page).
// Rendered by the shared Site layout.
const blurb = "Fast-tracking LLM apps\nto production";

const socials = [
  { platform: "x", url: "https://twitter.com/agenta_ai", icon: "/icons/social-1.svg" },
  {
    platform: "linkedin",
    url: "https://www.linkedin.com/company/agenta-ai/",
    icon: "/icons/social-2.svg",
  },
  {
    platform: "github",
    url: "https://github.com/agenta-ai/agenta",
    icon: "/icons/social-3.svg",
  },
  {
    platform: "slack",
    url: "https://join.slack.com/t/agenta-hq/shared_invite/zt-2yewk6o2b-DmhyA4h_lkKwecDtIsj1AQ",
    icon: "/icons/social-4.svg",
  },
  {
    platform: "youtube",
    url: "https://www.youtube.com/@agentaAI",
    icon: "/icons/social-5.svg",
  },
];

type Link = { label: string; href: string; external?: boolean };
const columns: { heading: string; links: Link[] }[] = [
  {
    heading: "Product",
    links: [
      {
        label: "Prompt Engineering",
        href: "https://agenta.ai/docs/prompt-engineering/quick-start",
        external: true,
      },
      {
        label: "Evaluation",
        href: "https://agenta.ai/docs/evaluation/evaluation-from-ui/quick-start",
        external: true,
      },
      {
        label: "Human annotation",
        href: "https://agenta.ai/docs/evaluation/human-evaluation/quick-start",
        external: true,
      },
      {
        label: "Deployment",
        href: "https://agenta.ai/docs/prompt-engineering/managing-prompts-programatically/deploy",
        external: true,
      },
      {
        label: "Observability",
        href: "https://agenta.ai/docs/observability/overview",
        external: true,
      },
    ],
  },
  {
    heading: "Company",
    links: [
      { label: "Home", href: "/" },
      { label: "Pricing", href: "/pricing" },
      // User override: keep our own /contact page (live links to /imprint).
      { label: "Contact", href: "/contact" },
    ],
  },
  {
    heading: "Resources",
    links: [
      { label: "Docs", href: "https://agenta.ai/docs/", external: true },
      {
        label: "Tutorial",
        href: "https://agenta.ai/docs/tutorials/cookbooks/capture-user-feedback",
        external: true,
      },
      {
        label: "Changelog",
        href: "https://agenta.ai/docs/changelog/main",
        external: true,
      },
      { label: "Roadmap", href: "https://agenta.ai/docs/roadmap", external: true },
      { label: "Blog", href: "/blog" },
      { label: "Status", href: "https://status.agenta.ai/", external: true },
    ],
  },
  {
    heading: "Legal",
    links: [
      { label: "Imprint", href: "/imprint" },
      {
        label: "Terms of services",
        href: "https://agenta.ai/docs/administration/security/terms-of-service",
        external: true,
      },
      {
        label: "Privacy Policy",
        href: "https://agenta.ai/docs/administration/security/privacy-policy",
        external: true,
      },
      {
        label: "DPA",
        href: "https://agenta.ai/docs/administration/security/dpa",
        external: true,
      },
      {
        label: "Trust Center",
        href: "https://trustcenter.agenta.ai/",
        external: true,
      },
    ],
  },
];

// Both "Privacy Policy" links (Legal column + bottom bar) point to the SAME
// destination — the docs privacy policy — per Mahmoud's instruction. (Live splits
// them termly-vs-docs; we deliberately unify to docs.)
const BOTTOM_PRIVACY_URL =
  "https://agenta.ai/docs/administration/security/privacy-policy";

const copyright = "Copyright © 2020 – 2060 Agentatech UG";
---

<footer
  style="background:#100F11;border:1px solid rgba(255,255,255,0.07);margin-top:-1px;box-sizing:border-box;"
>
  <div
    class="ag-foot-top"
    style="display:flex;justify-content:space-between;gap:64px;padding:64px 172px 96px;flex-wrap:wrap;"
  >
    <div style="display:flex;flex-direction:column;gap:16px;max-width:268px;">
      <img
        src="/logos/Agenta-logo-full-dark.svg"
        alt="Agenta"
        style="height:23px;width:fit-content;display:block;"
      />
      <span
        style="font:var(--text-label);line-height:1.25;color:rgba(255,255,255,0.6);white-space:pre-line;"
        >{blurb}</span
      >
      <div style="display:flex;gap:4px;margin-top:8px;">
        {
          socials.map((s) => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener"
              aria-label={s.platform}
              style="width:32px;height:32px;background:rgba(255,255,255,0.06);display:inline-flex;align-items:center;justify-content:center;"
            >
              <img
                src={s.icon}
                alt=""
                style="width:20px;height:20px;display:block;filter:invert(1) brightness(0.8);"
              />
            </a>
          ))
        }
      </div>
    </div>
    <div
      class="ag-foot-cols"
      style="display:flex;gap:64px;flex-wrap:wrap;"
    >
      {
        columns.map((col) => (
          <div style="display:flex;flex-direction:column;gap:12px;min-width:120px;">
            <span style="font:var(--text-caption);letter-spacing:0.03em;color:rgba(255,255,255,0.38);">
              {col.heading}
            </span>
            {col.links.map((link) => (
              <a
                class="ag-foot-link"
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener" : undefined}
                style="font:var(--text-label);color:rgba(255,255,255,0.62);cursor:pointer;text-decoration:none;"
              >
                {link.label}
              </a>
            ))}
          </div>
        ))
      }
    </div>
  </div>
  <div
    style="display:flex;justify-content:space-between;align-items:center;padding:16px 32px;border-top:1px solid rgba(255,255,255,0.07);"
  >
    <span style="font:var(--text-caption);color:rgba(255,255,255,0.38);"
      >{copyright}</span
    >
    <a
      class="ag-foot-link"
      href={BOTTOM_PRIVACY_URL}
      target="_blank"
      rel="noopener"
      style="font:var(--text-caption);color:rgba(255,255,255,0.38);text-decoration:none;"
      >Privacy policy</a
    >
  </div>
</footer>
