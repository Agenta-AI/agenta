---
// One pricing plan card. All content comes from the plan prop (src/data/pricing.json);
// this component owns only the card chrome. Chrome is uniform across every plan.
//
// Alignment invariant: the card is a subgrid child spanning four row tracks defined by
// the parent `.plan-grid`. Rows 1-3 (name+tagline, price, CTA) size to the tallest card
// in the row, so the divider that opens row 4 lands at the same Y across every card —
// structurally, with no per-card heights to tune when content in pricing.json changes.
// The chip is absolutely positioned (out of flow), so it never consumes a row track.
//
// Feature strings pass through `linkify` so tokens declared in pricing.json `links`
// (e.g. "GitHub Issues") render as anchors — the link text still comes from the data.
import { linkify, type PricingLink } from "../lib/pricingLinks";

interface Plan {
  name: string;
  tagline: string;
  price: string;
  unit: string;
  chip: string | null;
  cta: { label: string; href: string; style: "primary" | "outline" };
  includesLabel: string;
  features: string[];
}
const { plan, links = [] } = Astro.props as {
  plan: Plan;
  links?: PricingLink[];
};

const linkStyle =
  "color:var(--yellow-400);text-decoration:underline;text-underline-offset:2px;";

const card =
  "position:relative;display:grid;grid-row:span 4;grid-template-rows:subgrid;row-gap:16px;padding:28px 26px;border-radius:14px;box-sizing:border-box;background:rgba(255,255,255,0.025);box-shadow:inset 0 0 0 1px rgba(255,255,255,0.08);";

const ctaBase =
  "display:inline-flex;align-items:center;justify-content:center;width:100%;height:40px;border-radius:8px;font:var(--text-label);cursor:pointer;text-decoration:none;box-sizing:border-box;";
const ctaYellow =
  ctaBase +
  "background:var(--grad-btn-primary);box-shadow:var(--shadow-btn-primary);color:var(--ink-900);";
const ctaOutline =
  ctaBase +
  "background:rgba(255,255,255,0.04);box-shadow:inset 0 0 0 1px rgba(255,255,255,0.16);color:#fff;";
---

<div style={card}>
  {
    plan.chip && (
      <span style="position:absolute;top:-11px;left:50%;transform:translateX(-50%);z-index:1;display:inline-flex;align-items:center;height:22px;padding:0 12px;border-radius:999px;white-space:nowrap;background:#161417;box-shadow:inset 0 0 0 1px rgba(255,255,255,0.16);font:var(--text-caption);letter-spacing:0.02em;color:rgba(255,255,255,0.78);">
        {plan.chip}
      </span>
    )
  }

  <div style="display:flex;flex-direction:column;gap:6px;">
    <span style="font:300 22px/1.1 var(--font-display,'GT Alpina',serif);color:#F7F6F4;">
      {plan.name}
    </span>
    <span style="font:var(--text-body-sm);color:rgba(255,255,255,0.55);text-wrap:pretty;">
      {plan.tagline}
    </span>
  </div>

  <div style="display:flex;align-items:baseline;gap:7px;">
    <span style="font:300 44px/1 var(--font-display,'GT Alpina',serif);color:#F7F6F4;">
      {plan.price}
    </span>
    {
      plan.unit && (
        <span style="font:var(--text-body-sm);color:rgba(255,255,255,0.5);">
          {plan.unit}
        </span>
      )
    }
  </div>

  <a
    href={plan.cta.href}
    target="_blank"
    rel="noopener"
    style={plan.cta.style === "primary" ? ctaYellow : ctaOutline}
  >
    {plan.cta.label}
  </a>

  <div style="display:flex;flex-direction:column;gap:16px;">
    <div style="height:1px;background:rgba(255,255,255,0.08);"></div>
    <span style="font:var(--text-caption);letter-spacing:0.04em;color:rgba(255,255,255,0.45);">
      {plan.includesLabel}
    </span>
    <div style="display:flex;flex-direction:column;gap:11px;">
      {
        plan.features.map((f) => (
          <div style="display:flex;align-items:flex-start;gap:10px;">
            <svg
              width="16"
              height="16"
              viewBox="0 0 18 18"
              fill="none"
              style="margin-top:1px;flex:0 0 auto;"
            >
              <circle cx="9" cy="9" r="9" fill="var(--yellow-400)" />
              <path
                d="M5 9.2 7.6 11.8 13 6.4"
                stroke="var(--ink-900)"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <span style="font:var(--text-body-sm);color:rgba(255,255,255,0.72);">
              {linkify(f, links).map((part) => (part.href ? <a href={part.href} target={part.href.startsWith("mailto:") ? undefined : "_blank"} rel={part.href.startsWith("mailto:") ? undefined : "noopener"} style={linkStyle}>{part.text}</a> : <Fragment>{part.text}</Fragment>))}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</div>
