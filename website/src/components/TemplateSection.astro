---
import SectionTitle from "./SectionTitle.astro";
import TemplateExplorer from "./TemplateExplorer.tsx";
---

<section
  data-screen-label="Templates"
  class="ag-secpad"
  style="background:var(--ag-d-bg-2);border:1px solid rgba(255,255,255,0.07);margin-top:-1px;padding:var(--section-pad-y) 0;"
>
  <div
    style="display:flex;flex-direction:column;align-items:center;gap:48px;"
  >
    <SectionTitle
      dark
      badge="Templates"
      title="An agent for every job"
      subtitle="Start from a working template for engineering, support, sales, knowledge, and operations, then make it yours."
    />
    <!-- React island — hydrates when scrolled into view. -->
    <TemplateExplorer client:visible />
  </div>
</section>
