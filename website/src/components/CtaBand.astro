---
// Full-bleed yellow CTA band (the single yellow moment for this viewport). The
// two buttons replicate the live agenta.ai CTA keycaps exactly (dark gradient +
// white outline gradient, inset top-light shadow, 8px radius). The faded Agenta
// symbol is a large decorative mark clipped by the band (overflow:hidden), like
// the live site — non-interactive and aria-hidden.
const GET_STARTED = "https://cloud.agenta.ai/";
const BOOK_DEMO = "https://cal.com/mahmoud-mabrouk-ogzgey/demo?duration=30";

// Exact CTA-keycap CSS lifted from live agenta.ai (computed styles). Kept inline
// here so the band matches the live site without touching the shared button
// tokens (which the nav/hero also use). Height/padding follow our larger type
// scale rather than the live 36px/12px so the band CTA reads at page scale.
const btnBase =
  "display:inline-flex;align-items:center;justify-content:center;height:44px;padding:0 20px;border-radius:8px;font:var(--text-label);cursor:pointer;text-decoration:none;white-space:nowrap;box-sizing:border-box;";
const btnDark =
  btnBase +
  "--key-alpha:0.42;background:linear-gradient(180deg,#413F3E 0%,#1E1D1C 100%);box-shadow:inset 0 3px 6px rgba(255,255,255,0.3);color:#FFFFFF;";
const btnWhite =
  btnBase +
  "--key-alpha:1;background:linear-gradient(180deg,#F7F6F5 0%,#F1EEEC 100%);box-shadow:inset 0 3px 6px rgba(255,255,255,1);color:var(--ink-900);";
---

<section
  data-screen-label="CTA"
  class="ag-cta-sec"
  style="position:relative;overflow:hidden;background:var(--surface-cta);border:1px solid rgba(255,255,255,0.07);margin-top:-1px;padding:var(--section-pad-y) 24px;"
>
  <img
    class="ag-cta-img"
    src="/logos/Agenta-symbol-light.svg"
    alt=""
    aria-hidden="true"
    style="position:absolute;top:50%;right:-40px;transform:translateY(-50%);width:560px;opacity:0.1;pointer-events:none;z-index:0;"
  />
  <div
    class="ag-cta-row"
    style="position:relative;z-index:1;display:flex;align-items:center;justify-content:space-between;width:min(1072px,100%);margin:0 auto;gap:48px;"
  >
    <div style="display:flex;flex-direction:column;gap:24px;max-width:520px;">
      <h2
        style="margin:0;font:var(--text-display-lg);color:var(--text-on-yellow);text-wrap:pretty;"
      >
        Ship agents that actually work
      </h2>
      <p style="margin:0;font:var(--text-body-md);color:rgba(36,36,36,0.72);">
        Build with skills and tools, run on any harness in any environment, and
        improve with real feedback. All open source.
      </p>
      <div style="display:flex;gap:12px;">
        <a class="ag-key" href={GET_STARTED} style={btnDark}>Start building</a>
        <a class="ag-key" href={BOOK_DEMO} style={btnWhite}>Book a demo</a>
      </div>
    </div>
  </div>
</section>
