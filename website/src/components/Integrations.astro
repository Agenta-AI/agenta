---
import SectionTitle from "./SectionTitle.astro";

const integrations = [
  { name: "Slack", mono: "S" },
  { name: "PostHog", mono: "P" },
  { name: "GitHub", mono: "G" },
  { name: "Linear", mono: "L" },
  { name: "Sentry", mono: "S" },
  { name: "Datadog", mono: "D" },
  { name: "Webhooks", mono: "{}" },
  { name: "REST API", mono: "/" },
];
---

<section
  data-screen-label="Integrations"
  class="ag-secpad"
  style="background:var(--ag-d-bg-1);border:1px solid rgba(255,255,255,0.07);margin-top:-1px;padding:112px 0;"
>
  <div style="display:flex;flex-direction:column;align-items:center;gap:56px;">
    <SectionTitle
      dark
      badge="Integrations"
      title="Integrate with everything"
      subtitle="Dozens of built-in integrations push traces, feedback, and alerts to the tools your team already lives in."
    />
    <div
      class="ag-int"
      style="display:grid;grid-template-columns:repeat(4,1fr);width:min(1072px,100%);border:1px solid rgba(255,255,255,0.09);"
    >
      {
        integrations.map((item) => (
          <div style="display:flex;align-items:center;gap:14px;padding:24px 26px;box-shadow:0 0 0 0.5px rgba(255,255,255,0.09);">
            <span style="width:38px;height:38px;border-radius:9px;background:rgba(255,255,255,0.07);box-shadow:inset 0 0 0 1px rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;font:600 15px/1 var(--font-sans);color:rgba(255,255,255,0.85);">
              {item.mono}
            </span>
            <span style="font:var(--text-label);color:#F7F6F4;">
              {item.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
