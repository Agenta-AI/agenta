---
import SectionTitle from "./SectionTitle.astro";

const points = [
  "Capture feedback on every trace, from your team or your users",
  "Evaluate on real production data, not vibes",
  "Turn failures into test cases for continuous self-improvement",
];

const check = `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="margin-top:2px;flex:0 0 auto;"><circle cx="9" cy="9" r="9" fill="var(--yellow-400)"/><path d="M5 9.2 7.6 11.8 13 6.4" stroke="var(--ink-900)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
---

<section
  data-screen-label="Monitor"
  class="ag-secpad"
  style="background:#161518;border:1px solid rgba(255,255,255,0.07);margin-top:-1px;padding:112px 0;"
>
  <div
    class="ag-row"
    style="display:flex;align-items:center;gap:80px;width:min(1072px,100%);margin:0 auto;"
  >
    <div
      class="ag-video"
      style="flex:1;position:relative;height:340px;border-radius:8px;background:linear-gradient(180deg,#1C1B1E,#141315);box-shadow:0 24px 60px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.06);overflow:hidden;display:flex;align-items:center;justify-content:center;"
    >
      <img
        src="/logos/Agenta-symbol-dark.svg"
        alt=""
        style="position:absolute;right:-30px;top:-40px;width:220px;opacity:0.05;"
      />
      <div
        style="position:relative;display:flex;flex-direction:column;align-items:center;gap:14px;"
      >
        <div style="position:relative;width:64px;height:64px;">
          <span
            style="position:absolute;inset:0;border-radius:50%;background:var(--yellow-400);animation:ag-pulse 2.6s ease-out infinite;"
          ></span>
          <span
            style="position:relative;display:flex;align-items:center;justify-content:center;width:64px;height:64px;border-radius:50%;background:var(--yellow-400);box-shadow:0 8px 30px rgba(242,242,92,0.25);"
          >
            <svg width="18" height="20" viewBox="0 0 22 24" fill="none"
              ><path d="M2 2.5 19.5 12 2 21.5V2.5Z" fill="var(--ink-900)"
              ></path></svg
            >
          </span>
        </div>
        <span style="font:var(--text-label);color:rgba(255,255,255,0.66);"
          >Watch: monitoring &amp; evals</span
        >
      </div>
      <div
        style="position:absolute;bottom:16px;left:18px;font:var(--text-caption);letter-spacing:0.03em;color:rgba(255,255,255,0.4);"
      >
        1:38 · Observability
      </div>
    </div>
    <div style="flex:0 0 392px;display:flex;flex-direction:column;gap:24px;">
      <SectionTitle
        dark
        align="left"
        width="392px"
        badge="Observability"
        title="Monitor usage, improve quality"
        subtitle="Trace every run, collect user feedback, and run evaluations on real production data — then close the loop."
      />
      <div style="display:flex;flex-direction:column;gap:14px;">
        {
          points.map((p) => (
            <div style="display:flex;align-items:flex-start;gap:12px;">
              <Fragment set:html={check} />
              <span style="font:var(--text-body-sm);color:rgba(255,255,255,0.62);">
                {p}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
