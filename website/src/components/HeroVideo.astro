---
// Hero video placeholder (dark). Rendered only when Hero's SHOW_HERO_VIDEO flag
// is on; kept as a component so the card returns intact once a video asset lands.
---

<div
  class="ag-video"
  style="position:relative;width:min(1016px,100%);height:452px;margin-top:28px;border-radius:8px;background:linear-gradient(180deg,#1C1B1E,#141315);box-shadow:0 24px 70px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.06);overflow:hidden;display:flex;align-items:center;justify-content:center;"
>
  <img
    src="/logos/Agenta-symbol-dark.svg"
    alt=""
    style="position:absolute;left:-40px;bottom:-60px;width:340px;opacity:0.05;"
  />
  <div style="position:absolute;top:16px;left:16px;display:flex;gap:6px;">
    <span
      style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.14);"
    ></span>
    <span
      style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.14);"
    ></span>
    <span
      style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.14);"
    ></span>
  </div>
  <div
    style="position:relative;display:flex;flex-direction:column;align-items:center;gap:18px;"
  >
    <div style="position:relative;width:76px;height:76px;">
      <span
        style="position:absolute;inset:0;border-radius:50%;background:var(--yellow-400);animation:ag-pulse 2.6s ease-out infinite;"
      ></span>
      <span
        style="position:relative;display:flex;align-items:center;justify-content:center;width:76px;height:76px;border-radius:50%;background:var(--yellow-400);box-shadow:0 8px 30px rgba(242,242,92,0.25);"
      >
        <svg width="22" height="24" viewBox="0 0 22 24" fill="none"
          ><path d="M2 2.5 19.5 12 2 21.5V2.5Z" fill="var(--ink-900)"></path></svg
        >
      </span>
    </div>
    <span style="font:var(--text-label);color:rgba(255,255,255,0.66);"
      >Watch: build a support agent in 2 min</span
    >
  </div>
  <div
    style="position:absolute;bottom:16px;left:18px;font:var(--text-caption);letter-spacing:0.03em;color:rgba(255,255,255,0.4);"
  >
    2:04 · Product overview
  </div>
</div>
