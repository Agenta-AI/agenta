---
import Site from "../../layouts/Site.astro";
import PostCard from "../../components/PostCard.astro";
import CategoryFilter from "../../components/CategoryFilter.tsx";
import { getCollection } from "astro:content";
import { byDateDesc } from "../../lib/blog";

const all = (await getCollection("posts")).sort(byDateDesc);

// Featured: 1 primary (rank 1) + 2 secondary (ranks 2-3), per CONTENT_MODEL.md.
const featured = all.filter((p) => p.data.featured);
const primary = featured.find((p) => p.data.featuredRank === 1);
const secondary = featured
  .filter((p) => p.data.featuredRank === 2 || p.data.featuredRank === 3)
  .sort((a, b) => (a.data.featuredRank ?? 99) - (b.data.featuredRank ?? 99));

// The grid excludes the three featured posts so they don't render twice on the
// page (mirrors agenta.ai/blog, where the featured row and the grid are disjoint).
const featuredIds = new Set(
  [primary, ...secondary].filter(Boolean).map((p) => p!.id),
);
const gridPosts = all.filter((p) => !featuredIds.has(p.id));

// "Load more" pagination (mirrors agenta.ai/blog): the grid renders every post
// server-side (SEO + no-JS graceful — all visible without JS), and a small
// scoped script below reveals them PAGE_SIZE at a time. Featured row is separate
// and always shown, so it does not count toward the grid batch.
const PAGE_SIZE = 6;

// Filter pills = "All" + the distinct categories present, stable order.
const categories = [
  "All",
  ...["Engineering", "Article"].filter((c) =>
    all.some((p) => p.data.category === c),
  ),
];

const sectionBorder = "border:1px solid rgba(255,255,255,0.07);margin-top:-1px;";
---

<Site
  title="Blog — Agenta"
  description="The latest updates and insights from Agenta — prompt management, evaluation, and observability for LLM apps."
>
  <!-- Blog header -->
  <section
    class="ag-headpad ag-pad"
    style={`background:#0E0D0F;${sectionBorder}padding:120px 0 56px;text-align:center;`}
  >
    <div style="display:flex;flex-direction:column;align-items:center;gap:18px;">
      <span
        style="font:var(--text-caption);letter-spacing:0.14em;text-transform:uppercase;color:var(--yellow-400);"
        >Our blog</span
      >
      <h1
        class="ag-h1"
        style="margin:0;font:var(--text-display-xl);color:#F7F6F4;max-width:760px;text-wrap:pretty;"
      >
        Stories and insights
      </h1>
      <p
        style="margin:0;font:var(--text-body-md);color:rgba(255,255,255,0.6);max-width:560px;text-wrap:pretty;"
      >
        The latest updates and insights from Agenta — prompt management,
        evaluation, and observability for LLM apps.
      </p>
    </div>
  </section>

  <!-- Featured -->
  {
    primary && (
      <section
        class="ag-pad"
        style={`background:#0A0A0B;${sectionBorder}padding:64px 64px 24px;`}
      >
        <span style="display:block;font:var(--text-caption);letter-spacing:0.06em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:24px;">
          Featured blog post
        </span>
        <div class="ag-featrow" style="display:flex;gap:28px;">
          <div style="flex:1;min-width:0;display:flex;">
            <PostCard post={primary} variant="featured" />
          </div>
          {secondary.length > 0 && (
            <div
              class="ag-sec"
              style="flex:1;min-width:0;display:flex;flex-direction:column;gap:24px;"
            >
              {secondary.map((post) => (
                <PostCard post={post} variant="secondary" />
              ))}
            </div>
          )}
        </div>
      </section>
    )
  }

  <!-- All blogs -->
  <section
    class="ag-pad"
    style={`background:#0A0A0B;${sectionBorder}padding:32px 64px 88px;`}
  >
    <div
      style="display:flex;align-items:center;justify-content:space-between;gap:24px;margin-bottom:32px;flex-wrap:wrap;"
    >
      <h2 class="ag-dlg" style="margin:0;font:var(--text-display-lg);color:#F7F6F4;">
        All blogs
      </h2>
      <div class="ag-filter">
        <CategoryFilter categories={categories} client:visible />
      </div>
    </div>

    <div
      id="blog-grid"
      data-filter="All"
      data-page-size={PAGE_SIZE}
      class="ag-grid"
      style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;"
    >
      {gridPosts.map((post) => <PostCard post={post} variant="grid" />)}
    </div>

    <div
      id="blog-loadmore-wrap"
      style="display:none;justify-content:center;margin-top:40px;"
    >
      <button
        id="blog-loadmore"
        type="button"
        style="display:inline-flex;align-items:center;gap:8px;height:44px;padding:0 24px;border-radius:8px;border:none;cursor:pointer;background:rgba(255,255,255,0.04);box-shadow:inset 0 0 0 1px rgba(255,255,255,0.14);color:#fff;font:var(--text-label);"
      >
        Load more
      </button>
    </div>
  </section>

  <script>
    // Client-side "load more" for the blog grid. The grid is fully server-rendered
    // (all posts in the HTML, everything visible with JS off); this script reveals
    // them PAGE_SIZE at a time and composes with the CategoryFilter island, which
    // sets [data-filter] on #blog-grid. One place owns each card's visibility here
    // (inline display), so it wins over the no-JS filter CSS once JS runs.
    //
    // Filter + pagination: when a specific category is active we show ALL matching
    // posts and hide the button (the Engineering/Article subsets are small, and
    // agenta.ai's filtered pagination is not observable). "All" is paginated.
    (() => {
      const grid = document.getElementById("blog-grid");
      const wrap = document.getElementById("blog-loadmore-wrap");
      const btn = document.getElementById("blog-loadmore");
      if (!grid || !wrap || !btn) return;
      const cards = Array.from(grid.children) as HTMLElement[];
      const step = Number(grid.getAttribute("data-page-size")) || 6;
      let limit = step;

      const filterOf = () => grid.getAttribute("data-filter") || "All";

      const apply = () => {
        // Filtered view: let the category-filter CSS own visibility and reveal
        // every matching card (subsets are small); no pagination, no button.
        if (filterOf() !== "All") {
          for (const card of cards) card.classList.remove("blog-hidden");
          wrap.style.display = "none";
          return;
        }
        // "All" view: reveal the first `limit` cards, hide the rest.
        let shown = 0;
        for (const card of cards) {
          const visible = shown < limit;
          card.classList.toggle("blog-hidden", !visible);
          if (visible) shown++;
        }
        wrap.style.display = shown >= cards.length ? "none" : "flex";
      };

      btn.addEventListener("click", () => {
        limit += step;
        apply();
      });

      // The filter island flips [data-filter]; reset pagination when it changes.
      new MutationObserver(() => {
        limit = step;
        apply();
      }).observe(grid, { attributes: true, attributeFilter: ["data-filter"] });

      apply();
    })();
  </script>

  <style is:global>
    /* Category filter. The CategoryFilter island flips [data-filter] on
       #blog-grid; these rules hide the non-matching cards. The default
       (data-filter="All", and the no-JS state) shows every card. */
    #blog-grid[data-filter="Engineering"] > a:not([data-category="Engineering"]),
    #blog-grid[data-filter="Article"] > a:not([data-category="Article"]) {
      display: none;
    }

    /* Load-more pagination (All view only). The scoped script toggles
       .blog-hidden on grid cards beyond the current limit; this rule hides
       them. Only applies in the "All" view — filtered views strip
       .blog-hidden off every card, so it never fights the filter rule above. */
    #blog-grid > a.blog-hidden {
      display: none;
    }

    /* Grid + featured collapse mirrors agenta.ai/blog: grid 3 → 2 (≤1024) → 1
       (≤600); the featured row stacks below 1024. */
    @media (max-width: 1024px) {
      #blog-grid {
        grid-template-columns: repeat(2, 1fr) !important;
      }
      .ag-featrow {
        flex-direction: column !important;
      }
      .ag-sec {
        flex: 0 0 auto !important;
      }
    }
    @media (max-width: 600px) {
      #blog-grid {
        grid-template-columns: 1fr !important;
      }
      .ag-pad {
        padding-left: 20px !important;
        padding-right: 20px !important;
      }
    }
  </style>
</Site>
