---
import Site from "../layouts/Site.astro";

// Legal data confirmed by the founder on 2026-07-22 (register HRB 254081 B,
// VAT DE363150015, managing director). § 5 DDG replaced § 5 TMG in May 2024.
---

<Site
  title="Imprint — Agenta"
  description="Legal imprint for Agentatech UG (haftungsbeschränkt), Berlin. Required by § 5 DDG."
  showCta={false}
>
  <!-- ══ HERO ══════════════════════════════════════════════════════════ -->
  <section
    style="background:#0E0D0F;border-bottom:1px solid rgba(255,255,255,0.07);"
  >
    <div
      style="max-width:860px;margin:0 auto;padding:96px 32px 80px;"
    >
      <span
        style="display:inline-flex;align-items:center;height:24px;padding:0 13px;border-radius:999px;background:rgba(255,255,255,0.06);box-shadow:0 0 0 1px rgba(255,255,255,0.14);font:var(--text-caption);letter-spacing:0.06em;text-transform:uppercase;color:rgba(255,255,255,0.7);margin-bottom:24px;"
        >Legal</span
      >
      <h1
        style="margin:0 0 16px;font:var(--text-display-lg);color:#F7F6F4;text-wrap:pretty;"
      >
        Imprint
      </h1>
      <p
        style="margin:0;font:var(--text-body-md);color:rgba(255,255,255,0.6);max-width:540px;text-wrap:pretty;"
      >
        Information in accordance with § 5 DDG (Digitale-Dienste-Gesetz).
        This page also serves as the contact page for Agenta.
      </p>
    </div>
  </section>

  <!-- ══ CONTENT ═══════════════════════════════════════════════════════ -->
  <section style="background:#0A0A0B;padding:64px 32px 96px;">
    <div
      style="max-width:860px;margin:0 auto;display:flex;flex-direction:column;gap:32px;"
    >

      <!-- Legal notice panel -->
      <div
        style="border:1px solid rgba(255,255,255,0.07);padding:40px 40px 36px;background:#100F11;"
      >
        <h2
          style="margin:0 0 24px;font:300 28px/1.15 var(--font-display,'GT Alpina',serif);color:#F7F6F4;"
        >
          Legal notice
        </h2>

        <dl
          style="display:grid;grid-template-columns:160px 1fr;gap:12px 24px;font:var(--text-body-md);color:rgba(255,255,255,0.6);margin:0;"
        >
          <dt style="color:rgba(255,255,255,0.38);font:var(--text-label);">Company</dt>
          <dd style="margin:0;overflow-wrap:anywhere;">Agentatech UG (haftungsbeschränkt)</dd>

          <dt style="color:rgba(255,255,255,0.38);font:var(--text-label);">Address</dt>
          <dd style="margin:0;overflow-wrap:anywhere;">
            c/o betahaus<br />
            Rudi-Dutschke-Straße 23<br />
            10969 Berlin<br />
            Germany
          </dd>

          <dt style="color:rgba(255,255,255,0.38);font:var(--text-label);">Represented by</dt>
          <dd style="margin:0;overflow-wrap:anywhere;">Managing director (Geschäftsführer): Mahmoud Mabrouk</dd>

          <dt style="color:rgba(255,255,255,0.38);font:var(--text-label);">Commercial register</dt>
          <dd style="margin:0;overflow-wrap:anywhere;">
            Amtsgericht Charlottenburg (Berlin)<br />
            HRB 254081 B
          </dd>

          <dt style="color:rgba(255,255,255,0.38);font:var(--text-label);">VAT ID</dt>
          <dd style="margin:0;overflow-wrap:anywhere;">
            USt-IdNr. in accordance with § 27a UStG: DE363150015
          </dd>

          <dt style="color:rgba(255,255,255,0.38);font:var(--text-label);">Responsible for content</dt>
          <dd style="margin:0;overflow-wrap:anywhere;">
            Mahmoud Mabrouk (address as above), § 18 Abs. 2 MStV
          </dd>
        </dl>
      </div>

      <!-- Contact panel -->
      <div
        style="border:1px solid rgba(255,255,255,0.07);padding:40px 40px 36px;background:#100F11;"
      >
        <h2
          style="margin:0 0 24px;font:300 28px/1.15 var(--font-display,'GT Alpina',serif);color:#F7F6F4;"
        >
          Contact
        </h2>

        <dl
          style="display:grid;grid-template-columns:160px 1fr;gap:12px 24px;font:var(--text-body-md);color:rgba(255,255,255,0.6);margin:0;"
        >
          <dt style="color:rgba(255,255,255,0.38);font:var(--text-label);">Phone</dt>
          <dd style="margin:0;overflow-wrap:anywhere;">
            <a
              href="tel:+4915231036519"
              style="color:rgba(255,255,255,0.6);text-decoration:none;"
            >
              +49-(0)-152-31036519
            </a>
          </dd>

          <dt style="color:rgba(255,255,255,0.38);font:var(--text-label);">Email</dt>
          <dd style="margin:0;overflow-wrap:anywhere;">
            <a
              href="mailto:team@agenta.ai"
              style="color:rgba(255,255,255,0.6);text-decoration:none;"
            >
              team@agenta.ai
            </a>
          </dd>

          <dt style="color:rgba(255,255,255,0.38);font:var(--text-label);">Website</dt>
          <dd style="margin:0;overflow-wrap:anywhere;">
            <a
              href="https://agenta.ai"
              style="color:rgba(255,255,255,0.6);text-decoration:none;"
            >
              agenta.ai
            </a>
          </dd>
        </dl>
      </div>

    </div>
  </section>
</Site>
