# Cloudflare Workers Static Assets edge response headers.
# https://developers.cloudflare.com/workers/static-assets/headers/
#
# Rule matching is top-to-bottom; first match wins.
# Astro build emits content-hashed filenames under /_astro/; those can be
# cached forever. Font files under /fonts/ are also content-stable once
# uploaded to R2 and baked into dist.

# Hashed build assets — cache forever, immutable.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Licensed + open font files — cache forever, immutable.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# OG images and other public static assets — 1 week, revalidate.
/og/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/icons/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/logos/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Blog images (served from /blog/ and /authors/ under public/).
/blog/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/authors/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# HTML pages — short TTL; stale-while-revalidate so users see fresh content.
/*
  Cache-Control: public, max-age=60, stale-while-revalidate=3600
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
