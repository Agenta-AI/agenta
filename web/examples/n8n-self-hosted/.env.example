# Required: Agenta backend the n8n container will export OTel spans to.
# On Docker Desktop for Mac, host.docker.internal resolves to the host;
# on Linux Docker, add `extra_hosts: ["host.docker.internal:host-gateway"]`
# to docker-compose.yml.
AGENTA_HOST=http://host.docker.internal
AGENTA_API_KEY=<your-agenta-api-key>
AGENTA_PROJECT_ID=<your-agenta-project-id>

# Required for the workflow's OpenAI HTTP Request node.
OPENAI_API_KEY=<your-openai-api-key>

# Spike identity — surfaces as service.name on the OTel spans.
AGENTA_SPIKE_APP_NAME=n8n
