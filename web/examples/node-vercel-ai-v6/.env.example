# Required: Agenta endpoint + ingest key + project ID.
AGENTA_HOST=https://cloud.agenta.ai
AGENTA_API_KEY=your-agenta-api-key
AGENTA_PROJECT_ID=your-agenta-project-id

# Required: OpenAI key for the AI SDK calls.
OPENAI_API_KEY=your-openai-api-key

# Required: per-app namespace for the assertion-4 sentinel.
# (Prevents globalThis collisions when multiple spike apps run in the same Node process.)
AGENTA_SPIKE_APP_NAME=node

# Optional: override the OTLP path on the Agenta host.
# AGENTA_OTLP_PATH=/api/otlp/v1/traces

# Optional: override assertion-2's mid-stream-abort flush window (default 5s).
# ASSERTION_FLUSH_WINDOW_S=5
