{
    "name": "@agenta/spike-verify",
    "version": "0.0.0",
    "private": true,
    "description": "Verification harness for ts-sdk-tracing spike apps. Polls the Agenta API for ingested traces and asserts shape. Throws typed errors with diagnostic context. Retired when ts-sdk-tracing ships.",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "types:check": "tsc --noEmit",
        "lint": "eslint --config ../../../eslint.config.mjs src/ test/ --max-warnings 0",
        "lint:fix": "eslint --config ../../../eslint.config.mjs src/ test/ --max-warnings 0 --fix"
    },
    "dependencies": {
        "@agenta/sdk": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^20.8.10",
        "typescript": "5.8.3",
        "vitest": "^2.1.9"
    }
}
