{
    "name": "@agenta-spike/nextjs-app-router-raw",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "description": "Spike app: Next.js 16 App Router + AI SDK v6 + raw OpenTelemetry. Phase 2a app for ts-sdk-tracing design. See docs/design/ts-sdk-tracing/.",
    "scripts": {
        "dev": "next dev --port 3101",
        "build": "next build",
        "start": "next start --port 3101",
        "test:assertion-1": "tsx test/test-assertion-1.ts",
        "test:assertion-2": "tsx test/test-assertion-2.ts",
        "test:assertion-3": "tsx test/test-assertion-3.ts",
        "test:assertion-4": "tsx test/test-assertion-4.ts",
        "test": "pnpm run test:assertion-1 && pnpm run test:assertion-2 && pnpm run test:assertion-3 && pnpm run test:assertion-4",
        "lint": "eslint --config ../../eslint.config.mjs app/ test/ --max-warnings 0",
        "lint:fix": "eslint --config ../../eslint.config.mjs app/ test/ --max-warnings 0 --fix"
    },
    "dependencies": {
        "@agenta/spike-verify": "workspace:*",
        "@ai-sdk/openai": "^3.0.63",
        "@ai-sdk/react": "^3.0.0",
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
        "@opentelemetry/exporter-trace-otlp-proto": "^0.217.0",
        "@opentelemetry/resources": "^2.7.0",
        "@opentelemetry/sdk-trace-base": "^2.7.0",
        "@opentelemetry/sdk-trace-node": "^2.7.0",
        "@opentelemetry/semantic-conventions": "^1.40.0",
        "ai": "^6.0.177",
        "dotenv": "^16.4.7",
        "next": "16.2.6",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/node": "^20.8.10",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.10",
        "tsx": "^4.21.0",
        "typescript": "5.8.3"
    }
}
