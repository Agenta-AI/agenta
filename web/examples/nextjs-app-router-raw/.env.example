# Required: Agenta endpoint + ingest key + project ID.
AGENTA_HOST=https://cloud.agenta.ai
AGENTA_API_KEY=your-agenta-api-key
AGENTA_PROJECT_ID=your-agenta-project-id

# Required: OpenAI key for the AI SDK calls.
OPENAI_API_KEY=your-openai-api-key

# Required: per-app namespace for the assertion-4 sentinel.
AGENTA_SPIKE_APP_NAME=app-router-raw

# Optional: override the OTLP path on the Agenta host.
# AGENTA_OTLP_PATH=/api/otlp/v1/traces

# Optional: override assertion-2's mid-stream-abort flush window (default 5s).
# ASSERTION_FLUSH_WINDOW_S=5

# Local dev port (avoid clashing with the OSS app on 3000).
PORT=3101

# Optional Braintrust dual-export. Same OTel data fans out to both Agenta
# and Braintrust so you can compare what each platform displays for the
# IDENTICAL trace input. Leave unset to disable.
# BRAINTRUST_API_KEY=sk-...
# BRAINTRUST_OTLP_URL=https://api.braintrust.dev/otel/v1/traces

# Optional Langfuse tri-export. Auth is base64(LANGFUSE_PUBLIC_KEY:LANGFUSE_SECRET_KEY)
# in a Basic header. Leave unset to disable.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
