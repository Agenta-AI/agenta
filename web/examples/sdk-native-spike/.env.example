# OpenAI
OPENAI_API_KEY=sk-...

# Agenta (for the raw-OTel baseline)
AGENTA_HOST=https://cloud.agenta.ai
AGENTA_API_KEY=...
AGENTA_PROJECT_ID=...

# Langfuse (for langfuse-sdk.ts)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Braintrust (for braintrust-sdk.ts)
BRAINTRUST_API_KEY=sk-...
BRAINTRUST_PROJECT_NAME=sdk-native-spike
BRAINTRUST_APP_URL=https://www.braintrust.dev
# Their JS SDK reads BRAINTRUST_API_URL env var to switch regions; EU plane:
BRAINTRUST_API_URL=https://api-eu.braintrust.dev
