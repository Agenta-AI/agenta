{
    "name": "@agenta/primitive-ui",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "scripts": {
        "build": "pnpm run build:css && pnpm run types:check",
        "build:css": "tailwindcss -i src/styles/globals.css -o dist/styles.css --minify",
        "prepare": "pnpm run build:css",
        "types:check": "tsc --noEmit",
        "lint": "eslint --config ../eslint.config.mjs src/ --max-warnings 0",
        "lint:fix": "eslint --config ../eslint.config.mjs src/ --max-warnings 0 --fix",
        "test": "pnpm run types:check && pnpm run lint"
    },
    "exports": {
        "./styles.css": "./dist/styles.css",
        "./components/*": "./src/components/*.tsx",
        "./hooks/*": "./src/hooks/*.ts",
        "./lib/*": "./src/lib/*.ts"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "dependencies": {
        "@base-ui/react": "^1.6.0",
        "@phosphor-icons/react": "^2.1.10",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.3.2",
        "@tailwindcss/postcss": "^4.1.17",
        "@types/node": "^20.19.20",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "shadcn": "4.11.0",
        "tailwindcss": "^4.1.17",
        "typescript": "^5.9.3"
    }
}
