    "exports": {
        ".": "./src/index.ts"
    },
    "dependencies": {
        "@agentaai/api-client": "workspace:../agenta-api-client"
    },
    "devDependencies": {
        "@types/node": "^20.8.10",
        "typescript": "^5.9.3"
    }
}
