{
    "name": "@agenta/sdk",
    "version": "0.0.0-dev",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "prepare": "tsc -p tsconfig.json",
        "types:check": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint --config ../eslint.config.mjs src/ --max-warnings 0",
        "lint:fix": "eslint --config ../eslint.config.mjs src/ --max-warnings 0 --fix"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "dependencies": {
        "@agentaai/api-client": "workspace:../agenta-api-client"
    },
    "devDependencies": {
        "@types/node": "^20.8.10",
        "typescript": "^5.9.3"
    }
}
