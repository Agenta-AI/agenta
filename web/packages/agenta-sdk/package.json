{
    "name": "@agenta/sdk",
    "version": "0.0.0-dev",
    "private": true,
    "sideEffects": false,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "build": "pnpm run types:check",
        "types:check": "tsc --noEmit",
        "lint": "eslint --config ../eslint.config.mjs src/ --max-warnings 0",
