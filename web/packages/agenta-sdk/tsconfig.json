{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "rootDir": "src",
        "outDir": "dist",
        "noEmit": false,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "tsBuildInfoFile": ".tsbuildinfo"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
