FROM node:24-slim

ENV TURBO_TELEMETRY_DISABLED=1 \
    PNPM_HOME="/pnpm" \
    PATH="/pnpm:$PATH" \
    PNPM_CONFIG_FETCH_TIMEOUT=3600000 \
    PNPM_CONFIG_FETCH_RETRY_MINTIMEOUT=60000 \
    PNPM_CONFIG_FETCH_RETRY_MAXTIMEOUT=600000 \
    PNPM_CONFIG_FETCH_RETRIES=10 \
    PNPM_CONFIG_FETCH_MIN_SPEED_KI_BPS=0 \
    PNPM_CONFIG_FETCH_WARN_TIMEOUT_MS=600000

WORKDIR /app

RUN npm install -g corepack@0.31.0 && \
    corepack enable

# Install dependencies based on the preferred package manager
COPY package.json yarn.lock* package-lock.json* pnpm-lock.yaml* .npmrc* ./
COPY patches/ ./patches/
COPY ./entrypoint.sh /app/entrypoint.sh

# Activate the pnpm version declared in package.json's `packageManager` field.
# Corepack natively understands the `+sha512.<hash>` integrity suffix.
RUN PNPM_VERSION=$(node -p "require('./package.json').packageManager.split('@')[1]") && \
    corepack prepare "pnpm@${PNPM_VERSION}" --activate

# Copy app package manifests
COPY oss/package.json ./oss/yarn.lock* ./oss/package-lock.json* ./oss/pnpm-lock.yaml* ./oss/.npmrc* ./oss/

# Copy workspace package manifests (required for workspace:* resolution)
COPY packages/agenta-shared/package.json ./packages/agenta-shared/
COPY packages/agenta-ui/package.json ./packages/agenta-ui/
COPY packages/agenta-entities/package.json ./packages/agenta-entities/
COPY packages/agenta-entity-ui/package.json ./packages/agenta-entity-ui/
COPY packages/agenta-playground/package.json ./packages/agenta-playground/
COPY packages/agenta-playground-ui/package.json ./packages/agenta-playground-ui/
COPY packages/agenta-annotation/package.json ./packages/agenta-annotation/
COPY packages/agenta-annotation-ui/package.json ./packages/agenta-annotation-ui/
COPY packages/agenta-sdk/package.json ./packages/agenta-sdk/

# `agenta-api-client` runs `tsc` as a `prepare` lifecycle script during install.
# Its source (src/, tsconfig.json) must be present before `pnpm i` runs, so we
# copy the whole directory here rather than just the manifest.
COPY packages/agenta-api-client/ ./packages/agenta-api-client/

# Copy shared package config files (required by package tsconfigs)
COPY packages/tsconfig.base.json ./packages/
COPY packages/css-modules.d.ts ./packages/

# Copy tests workspace manifest (OSS depends on @agenta/web-tests)
COPY tests/package.json ./tests/

COPY ./pnpm-workspace.yaml ./turbo.json ./
RUN groupadd --gid 10001 agenta && \
    useradd --uid 10001 --gid 10001 --shell /bin/false --create-home agenta && \
    mkdir -p /app/.turbo /app/oss/.next/cache && \
    chown -R agenta:agenta /app

USER 10001

RUN --mount=type=cache,id=pnpm-oss-dev,target=/pnpm/store,uid=10001,gid=10001 \
    pnpm fetch --frozen-lockfile

RUN --mount=type=cache,id=pnpm-oss-dev,target=/pnpm/store,uid=10001,gid=10001 \
    pnpm i --frozen-lockfile --offline

COPY --chown=agenta:agenta tsconfig.json .

# Copy workspace package sources (after install to preserve layer caching)
COPY --chown=agenta:agenta packages/agenta-sdk/src ./packages/agenta-sdk/src
COPY --chown=agenta:agenta packages/agenta-sdk/tsconfig.json ./packages/agenta-sdk/
# `agenta-api-client` was fully copied before install (for the prepare script)
# so no second source copy is needed here.
COPY --chown=agenta:agenta packages/agenta-shared/src ./packages/agenta-shared/src
COPY --chown=agenta:agenta packages/agenta-shared/tsconfig.json ./packages/agenta-shared/
COPY --chown=agenta:agenta packages/agenta-ui/src ./packages/agenta-ui/src
COPY --chown=agenta:agenta packages/agenta-ui/tsconfig.json ./packages/agenta-ui/
COPY --chown=agenta:agenta packages/agenta-entities/src ./packages/agenta-entities/src
COPY --chown=agenta:agenta packages/agenta-entities/tsconfig.json ./packages/agenta-entities/
COPY --chown=agenta:agenta packages/agenta-entity-ui/src ./packages/agenta-entity-ui/src
COPY --chown=agenta:agenta packages/agenta-entity-ui/tsconfig.json ./packages/agenta-entity-ui/
COPY --chown=agenta:agenta packages/agenta-playground/src ./packages/agenta-playground/src
COPY --chown=agenta:agenta packages/agenta-playground/tsconfig.json ./packages/agenta-playground/
COPY --chown=agenta:agenta packages/agenta-playground-ui/src ./packages/agenta-playground-ui/src
COPY --chown=agenta:agenta packages/agenta-playground-ui/tsconfig.json ./packages/agenta-playground-ui/
COPY --chown=agenta:agenta packages/agenta-annotation/src ./packages/agenta-annotation/src
COPY --chown=agenta:agenta packages/agenta-annotation/tsconfig.json ./packages/agenta-annotation/
COPY --chown=agenta:agenta packages/agenta-annotation-ui/src ./packages/agenta-annotation-ui/src
COPY --chown=agenta:agenta packages/agenta-annotation-ui/tsconfig.json ./packages/agenta-annotation-ui/

COPY --chown=agenta:agenta oss/src ./oss/src
COPY --chown=agenta:agenta oss/public ./oss/public
COPY --chown=agenta:agenta oss/tsconfig.json ./oss

COPY --chown=agenta:agenta oss/postcss.config.mjs ./oss/postcss.config.mjs

COPY --chown=agenta:agenta oss/next.config.ts ./oss/next.config.ts

COPY --chown=agenta:agenta oss/tailwind.config.ts ./oss/tailwind.config.ts


ENTRYPOINT ["./entrypoint.sh"]
EXPOSE 3000
