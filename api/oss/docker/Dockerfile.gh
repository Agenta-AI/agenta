ARG UV_VERSION=0.11.14
FROM ghcr.io/astral-sh/uv:${UV_VERSION} AS uv

FROM python:3.13-slim-trixie AS builder

ARG UV_VERSION

WORKDIR /app

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=0 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_PROJECT_ENVIRONMENT=/opt/venv \
    UV_LINK_MODE=copy

COPY --from=uv /uv /uvx /bin/

# Build context is `application/` so `uv sync` can resolve the local-path source
# `agenta = { path = "../sdks/python", editable = true }` declared in api/pyproject.toml.
COPY ./api/pyproject.toml ./api/uv.lock* /app/
COPY ./sdks/python /sdks/python/
COPY ./clients/python /clients/python/

# Install full deps (including the editable local SDK + client) in one pass,
# then strip heavy unused transitives, then stub out import-time-only deps.
# Merged into one layer so stripped files don't persist in a previous layer.
# Stripped:
# - phonenumbers/twilio: required by supertokens at import-time but never called
# - hf_xet: transitive, never imported by app code
# Kept: litellm + chain (tokenizers, huggingface_hub, tiktoken) — needed by agenta SDK
# Kept: newrelic — used for observability
RUN --mount=type=cache,id=pip-api,target=/root/.cache/pip \
    --mount=type=cache,id=uv-api,target=/root/.cache/uv \
    UV_HTTP_TIMEOUT=300 uv sync --locked --no-dev \
    && SITE=$(/opt/venv/bin/python -c 'import site; print(site.getsitepackages()[0])') \
    && rm -rf \
        ${SITE}/phonenumbers* \
        ${SITE}/twilio* \
        ${SITE}/hf_xet* \
    && mkdir -p ${SITE}/phonenumbers ${SITE}/twilio/rest \
    && printf 'PhoneNumberFormat=type("PhoneNumberFormat",(),{"E164":0,"INTERNATIONAL":1,"NATIONAL":2})()\ndef parse(*a,**k):return None\ndef format_number(*a,**k):return ""\ndef is_valid_number(*a,**k):return False\n' \
        > ${SITE}/phonenumbers/__init__.py \
    && printf 'class Client:\n    def __init__(self,*a,**k):raise NotImplementedError("twilio stub")\n' \
        > ${SITE}/twilio/__init__.py \
    && cp ${SITE}/twilio/__init__.py ${SITE}/twilio/rest/__init__.py \
    && find /opt/venv -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null; true

# Copy app code last (changes more frequently)
COPY ./api/oss /app/oss/
COPY ./api/entrypoints /app/entrypoints/


FROM python:3.13-slim-trixie AS runner

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=0.0.0

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app:/sdks/python:/clients/python \
    PATH="/opt/venv/bin:${PATH}"

# Hardcode trixie codename to avoid pulling in lsb-release (+ perl ~56MB).
# IMPORTANT: This codename must match the Debian release used in the base image (python:3.13-slim-trixie).
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl gnupg2 && \
    echo "deb http://apt.postgresql.org/pub/repos/apt trixie-pgdg main" > /etc/apt/sources.list.d/pgdg.list && \
    curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc | \
    gpg --dearmor -o /etc/apt/trusted.gpg.d/postgresql.gpg && \
    apt-get update && \
    apt-get install -y --no-install-recommends postgresql-client-17 && \
    apt-get purge -y --auto-remove gnupg2 && \
    rm -rf /var/lib/apt/lists/*

# Install supercronic (non-root-compatible cron daemon)
ARG SUPERCRONIC_VERSION=v0.2.36
RUN ARCH=$(dpkg --print-architecture) && \
    case "${ARCH}" in \
      amd64) SHA1=53a484404b0c559d64f78e9481a3ec22f782dc46 ;; \
      arm64) SHA1=58b3c15304e7b59fe7b9d66a2242f37e71cf7db6 ;; \
      *) echo "Unsupported arch: ${ARCH}" && exit 1 ;; \
    esac && \
    curl -fsSL "https://github.com/aptible/supercronic/releases/download/${SUPERCRONIC_VERSION}/supercronic-linux-${ARCH}" \
      -o /usr/local/bin/supercronic && \
    echo "${SHA1}  /usr/local/bin/supercronic" | sha1sum -c - && \
    chmod +x /usr/local/bin/supercronic

RUN groupadd --gid 10001 agenta && \
    useradd --uid 10001 --gid 10001 --shell /bin/false --create-home agenta

# Copy stable cron files first (change less frequently)
COPY --chmod=755 ./api/oss/src/crons/queries.sh /queries.sh
COPY --chmod=644 ./api/oss/src/crons/queries.txt /etc/cron.d/queries-cron

# Copy dependencies from builder
COPY --from=builder /opt/venv /opt/venv

# Copy app code last (changes most frequently)
COPY --chown=agenta:agenta --from=builder /app/oss /app/oss
COPY --chown=agenta:agenta --from=builder /app/entrypoints /app/entrypoints
COPY --chown=agenta:agenta --from=builder /sdks/python /sdks/python
COPY --chown=agenta:agenta --from=builder /clients/python /clients/python

# Generate supercronic-compatible crontab (strip user field and /proc redirects)
RUN set -eux; \
    for cron_file in /etc/cron.d/queries-cron; do \
        sed -i -e '$a\' "${cron_file}"; \
    done; \
    sed -E 's/^(([^[:space:]]+[[:space:]]+){5})root[[:space:]]+/\1/' /etc/cron.d/queries-cron \
        | sed 's| >> /proc/1/fd/1 2>&1||' > /app/crontab && \
    chown agenta:agenta /app/crontab

USER 10001

LABEL org.opencontainers.image.title="agenta-api" \
    org.opencontainers.image.description="Agenta API GH runtime image" \
    org.opencontainers.image.version="${VERSION}" \
    org.opencontainers.image.revision="${VCS_REF}" \
    org.opencontainers.image.created="${BUILD_DATE}"

EXPOSE 8000
