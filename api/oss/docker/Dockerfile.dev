ARG UV_VERSION=0.11.14
FROM ghcr.io/astral-sh/uv:${UV_VERSION} AS uv

FROM python:3.13-slim-trixie

WORKDIR /app

ENV UV_PROJECT_ENVIRONMENT=/opt/venv \
    UV_CACHE_DIR=/root/.cache/uv \
    UV_LINK_MODE=copy \
    PATH="/opt/venv/bin:${PATH}"

RUN --mount=type=cache,id=apt-api-oss-dev-cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=apt-api-oss-dev-lists,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends curl gnupg2 lsb-release ca-certificates && \
    echo "deb http://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" > /etc/apt/sources.list.d/pgdg.list && \
    curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc | \
    gpg --dearmor -o /etc/apt/trusted.gpg.d/postgresql.gpg && \
    apt-get update && \
    apt-get install -y --no-install-recommends postgresql-client-17

# Install supercronic (non-root-compatible cron daemon)
ARG SUPERCRONIC_VERSION=v0.2.36
RUN ARCH=$(dpkg --print-architecture) && \
    case "${ARCH}" in \
      amd64) SHA1=53a484404b0c559d64f78e9481a3ec22f782dc46 ;; \
      arm64) SHA1=58b3c15304e7b59fe7b9d66a2242f37e71cf7db6 ;; \
      *) echo "Unsupported arch: ${ARCH}" && exit 1 ;; \
    esac && \
    curl -fsSL "https://github.com/aptible/supercronic/releases/download/${SUPERCRONIC_VERSION}/supercronic-linux-${ARCH}" \
      -o /usr/local/bin/supercronic && \
    echo "${SHA1}  /usr/local/bin/supercronic" | sha1sum -c - && \
    chmod +x /usr/local/bin/supercronic

COPY --from=uv /uv /uvx /bin/

# Build context is `application/` so `uv sync` can resolve the local-path source
# `agenta = { path = "../sdks/python", editable = true }` declared in api/pyproject.toml.
COPY ./api/pyproject.toml ./api/uv.lock* /app/
COPY ./sdks/python/pyproject.toml ./sdks/python/README.md /sdks/python/
COPY ./clients/python/pyproject.toml /clients/python/

RUN --mount=type=cache,id=uv-dev,target=/root/.cache/uv,sharing=locked \
    UV_HTTP_TIMEOUT=300 uv sync --locked --no-install-local

COPY ./sdks/python /sdks/python/
COPY ./clients/python /clients/python/

RUN --mount=type=cache,id=uv-dev,target=/root/.cache/uv,sharing=locked \
    UV_HTTP_TIMEOUT=300 uv pip install --python /opt/venv/bin/python --no-deps --editable /clients/python --editable /sdks/python

#
RUN groupadd --gid 10001 agenta && \
    useradd --uid 10001 --gid 10001 --shell /bin/false --create-home agenta

COPY --chown=agenta:agenta ./api/oss /app/oss/
COPY --chown=agenta:agenta ./api/entrypoints /app/entrypoints/

ENV PYTHONPATH=/sdks/python:/clients/python

COPY ./api/oss/src/crons/queries.sh /queries.sh
COPY ./api/oss/src/crons/queries.txt /etc/cron.d/queries-cron
COPY ./api/oss/src/crons/triggers.sh /triggers.sh
COPY ./api/oss/src/crons/triggers.txt /etc/cron.d/triggers-cron

RUN chmod +x /queries.sh /triggers.sh \
    && chmod 0644 /etc/cron.d/queries-cron /etc/cron.d/triggers-cron \
    && sed -i -e '$a\' /etc/cron.d/queries-cron \
    && sed -i -e '$a\' /etc/cron.d/triggers-cron \
    && sed -E 's/^(([^[:space:]]+[[:space:]]+){5})root[[:space:]]+/\1/' /etc/cron.d/queries-cron /etc/cron.d/triggers-cron \
        | sed 's| >> /proc/1/fd/1 2>&1||' > /app/crontab \
    && chown agenta:agenta /app/crontab

USER 10001

EXPOSE 8000
