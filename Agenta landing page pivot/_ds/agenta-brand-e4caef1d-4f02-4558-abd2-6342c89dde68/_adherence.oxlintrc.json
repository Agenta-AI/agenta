{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/app/**",
              "components/buttons/**",
              "components/marketing/**",
              "ui_kits/web_app/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:GT Alpina|PP Mondwest|Inter|Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: GT Alpina, PP Mondwest, Inter, Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<AppButton> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:dark|default)$/]",
        "message": "<AppButton> variant must be one of 'dark' | 'default'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppSidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:workspace|sections|footerItems|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<AppSidebar> doesn't accept that prop. Declared props: workspace, sections, footerItems, onSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|dark|yellow)$/]",
        "message": "<Badge> variant must be one of 'default' | 'dark' | 'yellow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline|dark|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'outline' | 'dark' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FAQItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|answer|defaultOpen|style|key|ref|className|style|children)$/]",
        "message": "<FAQItem> doesn't accept that prop. Declared props: question, answer, defaultOpen, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|socialSrcs|columns|style|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: logoSrc, socialSrcs, columns, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HighlightChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|fontSize|style|key|ref|className|style|children)$/]",
        "message": "<HighlightChip> doesn't accept that prop. Declared props: children, fontSize, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|links|withChevron|style|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: logoSrc, links, withChevron, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PillTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|onChange|style|key|ref|className|style|children)$/]",
        "message": "<PillTabs> doesn't accept that prop. Declared props: tabs, active, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchField'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|icon|label|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SearchField> doesn't accept that prop. Declared props: placeholder, icon, label, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute > JSXIdentifier[name!=/^(?:badge|title|subtitle|dark|align|size|style|key|ref|className|style|children)$/]",
        "message": "<SectionTitle> doesn't accept that prop. Declared props: badge, title, subtitle, dark, align, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<SectionTitle> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|xl)$/]",
        "message": "<SectionTitle> size must be one of 'lg' | 'xl'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
