**/*.pyc.*
**/*/node_modules
**/*.next
**/*.pnpm-store
**/*.env*
!**/*.env.example*
!**/*env.example*
**/*.DS_Store
**/*.vscode
**/*.pem
**/*dont_commit_me*
web/packages/agenta-api-client/dist/
web/packages/agenta-sdk/dist/

