# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
**/*.pyc
**/*.pyc.*
__pycache__/
**/__pycache__/

# ------------------------------------------------------------------------------
# JavaScript / Node.js
# ------------------------------------------------------------------------------
**/*/node_modules
**/*.next
**/*.pnpm-store
.nextjs_cache/

# ------------------------------------------------------------------------------
# Environment / local secrets
# ------------------------------------------------------------------------------
**/*.env*
!**/*.env.example*

# ------------------------------------------------------------------------------
# OS / editor / local-only files
# ------------------------------------------------------------------------------
**/*.DS_Store
**/*.vscode
**/*.pem
**/*dont_commit_me*
web/packages/agenta-api-client/dist/

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
**/error-*.log

# ------------------------------------------------------------------------------
# Local virtual environments / build outputs
# ------------------------------------------------------------------------------
/.nox/
/docs/_build/
env/
myenv/

# ------------------------------------------------------------------------------
# Examples
# ------------------------------------------------------------------------------
examples/**/config.toml
examples/**/agenta.py
examples/**/storage/
examples/**/entrypoint.sh
examples/**/agenta/
examples/**/old
examples/**/docker.tar.gz
examples/**/Dockerfile

# ------------------------------------------------------------------------------
# Web
# ------------------------------------------------------------------------------
web/src/ee/**
web/src/pages/apps/index.tsx
web/src/pages/auth/[[...path]].tsx
web/ee/public/__env.js
web/oss/public/__env.js

# sdks/
sdks/python/tests/test_sdk_locally/config.toml
sdks/python/agenta/client/fern
sdks/python/agenta/templates/main.py
sdks/python/agenta/templates/agenta.py
web/ee/public/__env.js
web/oss/public/__env.js

# ------------------------------------------------------------------------------
# Test outputs / generated results
# ------------------------------------------------------------------------------
web/tests/results
web/tests/reports
web/oss/tests/results
web/ee/tests/results
api/oss/tests/results/
api/ee/tests/results/
sdks/python/oss/tests/results/
sdks/python/ee/tests/results/
services/oss/tests/results/
services/ee/tests/results/
tests/results/

# ------------------------------------------------------------------------------
# Temporary local SDK links created by run.sh --local
# ------------------------------------------------------------------------------
api/sdk
services/sdk

# ------------------------------------------------------------------------------
# Keep tracked placeholders / repo config
# ------------------------------------------------------------------------------
!**/.gitkeep
!.github/
!.github/**
!.husky/
!.husky/**
!api/.dockerignore
!services/.dockerignore
!.env.example
!web/.prettierignore

# Temporary SDK copies created by run.sh --local
api/sdks
services/sdks

# Helm chart packages (built artifacts)
agenta-oss-*.tgz

# IDE/LSP config (local tooling)
pyrightconfig.json
