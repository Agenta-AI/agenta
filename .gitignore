examples/**/package-lock.json

__pycache__/
**/__pycache__/

**/error-*.log
**/*.logs

/.nox/
/docs/_build/
env/
myenv/

**/error-*.log

# examples/
examples/**/config.toml
examples/**/agenta.py
examples/**/main.py
examples/**/storage/
examples/**/entrypoint.sh
examples/**/agenta/
examples/**/old
examples/**/docker.tar.gz
examples/**/Dockerfile

# web/
web/src/ee/**
web/src/pages/apps/index.tsx
web/src/pages/auth/[[...path]].tsx
web/src/pages/auth/[[...path]].tsx
.nextjs_cache/

# sdks/
sdks/python/tests/test_sdk_locally/config.toml
sdks/python/agenta/client/fern
sdks/python/agenta/templates/main.py
sdks/python/agenta/templates/agenta.py
web/ee/public/__env.js
web/oss/public/__env.js

web/tests/results
web/tests/reports
web/oss/tests/results
web/ee/tests/results
api/oss/tests/results/
api/ee/tests/results/
sdks/python/oss/tests/results/
sdks/python/ee/tests/results/
services/oss/tests/results/
services/ee/tests/results/
.*
!**/.gitkeep
!.github/
!.github/**
!.husky/
!.husky/**
!.dockerignore
!api/.dockerignore
!services/.dockerignore
!.env.example
!web/.prettierignore
# `web/examples/.shared/` is a pnpm workspace root (see web/pnpm-workspace.yaml).
# The dot-prefix is intentional (carves it out of the default `examples/*` glob),
# but the `.*` rule above would otherwise silently ignore it — and historically did,
# costing the ts-sdk-tracing spike its verification harness on a fresh checkout.
# We un-ignore the directory but re-ignore the usual build/install artifacts.
!web/examples/.shared/
!web/examples/.shared/**
web/examples/.shared/**/node_modules/
web/examples/.shared/**/.turbo/
web/examples/.shared/**/dist/
web/examples/.shared/**/.vite/

# Temporary SDK copies created by run.sh --local
api/sdks
services/sdks

# Helm chart packages (built artifacts)
agenta-oss-*.tgz

# Local Kubernetes Helm values. Keep example values files tracked.
hosting/kubernetes/**/.values.*.yaml
hosting/kubernetes/**/values.*.yaml
!hosting/kubernetes/**/values.*.example.yaml

# IDE/LSP config (local tooling)
pyrightconfig.json
.gstack/
