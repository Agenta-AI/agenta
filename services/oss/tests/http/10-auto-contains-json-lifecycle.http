@host = http://localhost
@token = change-me-auth
@api_url = {{host}}/api
@services_url = {{host}}/services

###
# @name create_account
POST {{api_url}}/admin/account
Content-Type: application/json
Authorization: Access {{token}}

###
@authorization = {{create_account.response.body.scopes[0].credentials}}

###
# 0. Fetch catalog
# @name fetch_catalog
GET {{api_url}}/preview/evaluators/catalog/templates/
Authorization: {{authorization}}

###
# 1. Inspect the auto_contains_json template (schema + uri)
# @name get_template
GET {{api_url}}/preview/evaluators/catalog/templates/auto_contains_json
Authorization: {{authorization}}

###
# 2. Create workflow — artifact + variant + committed revision in one shot
# @name create_workflow
POST {{api_url}}/preview/simple/workflows/
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow": {
    "slug": "test-auto-contains-json-manual",
    "name": "test-auto-contains-json-manual",
    "flags": {
      "is_evaluator": true
    },
    "data": {
      "uri": "agenta:builtin:auto_contains_json:v0",
      "parameters": {}
    }
  }
}

###
@workflow_slug = {{create_workflow.response.body.workflow.slug}}
@revision_id   = {{create_workflow.response.body.workflow.revision_id}}
@workflow_url  = {{create_workflow.response.body.workflow.data.url}}

###
# 3. Query environments — find the default one
# @name query_environments
POST {{api_url}}/preview/environments/query
Content-Type: application/json
Authorization: {{authorization}}

{}

###
@environment_id   = {{query_environments.response.body.environments[0].id}}
@environment_slug = {{query_environments.response.body.environments[0].slug}}

###
# 4. Deploy revision to environment
# @name deploy
POST {{api_url}}/preview/workflows/revisions/deploy
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow_revision_ref": { "id": "{{revision_id}}" },
  "environment_ref":       { "id": "{{environment_id}}" }
}

###
# 4b. Check environment revision — verify data.references contains the deployed key
# @name check_env_revision
POST {{api_url}}/preview/environments/revisions/retrieve
Content-Type: application/json
Authorization: {{authorization}}

{
  "environment_ref": { "id": "{{environment_id}}" }
}

###
# 5a. Invoke — direct service mount, no dispatcher
# output is valid JSON → expect success=true
# @name invoke_direct
POST {{services_url}}/builtin/auto_contains_json/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     {},
    "outputs":    "{\"city\": \"Paris\"}",
    "parameters": {}
  }
}

###
# 5b. Invoke — /invoke with URI + parameters inline, zero DB calls
# @name invoke_inline
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "{\"city\": \"Paris\"}",
    "revision": {
      "data": {
        "uri": "agenta:builtin:auto_contains_json:v0",
        "parameters": {}
      }
    }
  }
}

###
# 5c. Invoke — /invoke with env ref + selector key (SDK resolves via retrieve)
# @name invoke_by_env
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "references": {
    "environment": { "slug": "{{environment_slug}}" }
  },
  "selector": {
    "key": "{{workflow_slug}}.revision"
  },
  "data": {
    "inputs":  {},
    "outputs": "{\"city\": \"Paris\"}"
  }
}

###
# 5d. Invoke — via data.url inferred from URI (full URL, no dispatcher)
# @name invoke_by_url
POST {{workflow_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     {},
    "outputs":    "{\"city\": \"Paris\"}",
    "parameters": {}
  }
}

###
# BONUS — invalid JSON output: expect success=false
# @name invoke_invalid_json
POST {{services_url}}/builtin/auto_contains_json/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     {},
    "outputs":    "not valid json at all",
    "parameters": {}
  }
}
