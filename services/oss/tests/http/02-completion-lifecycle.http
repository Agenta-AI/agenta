@host = http://localhost
@token = change-me-auth
@api_url = {{host}}/api
@services_url = {{host}}/services

###
# @name create_account
POST {{api_url}}/admin/account
Content-Type: application/json
Authorization: Access {{token}}

###
@authorization = {{create_account.response.body.scopes[0].credentials}}

###
# 1. Inspect the completion template (schema + uri)
# @name get_template
GET {{api_url}}/preview/workflows/catalog/templates/completion
Authorization: {{authorization}}

###
# 2. Create workflow — artifact + variant + committed revision in one shot
# @name create_workflow
POST {{api_url}}/preview/simple/workflows/
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow": {
    "slug": "test-completion-manual",
    "name": "test-completion-manual",
    "flags": {
      "is_application": true
    },
    "data": {
      "uri": "agenta:builtin:completion:v0",
      "parameters": {
        "prompt": {
          "system_prompt": "You are an expert in geography",
          "user_prompt": "What is the capital of {{country}}?",
          "llm_config": {
            "model": "gpt-4o-mini"
          }
        }
      }
    }
  }
}

###
@workflow_slug = {{create_workflow.response.body.workflow.slug}}
@revision_id   = {{create_workflow.response.body.workflow.revision_id}}

###
# 3. Query environments — find the default one
# @name query_environments
POST {{api_url}}/preview/environments/query
Content-Type: application/json
Authorization: {{authorization}}

{}

###
@env_id   = {{query_environments.response.body.environments[0].id}}
@env_slug = {{query_environments.response.body.environments[0].slug}}

###
# 4. Deploy revision to environment
# @name deploy
POST {{api_url}}/preview/workflows/revisions/deploy
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow_revision_ref": { "id": "{{revision_id}}" },
  "environment_ref":       { "id": "{{env_id}}" }
}

###
# 5a. Invoke — direct service mount, no dispatcher
# NOTE: requires a valid LLM API key configured in Agenta vault
# @name invoke_direct
POST {{services_url}}/completion/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs": { "country": "France" },
    "parameters": {
      "prompt": {
        "system_prompt": "You are an expert in geography",
        "user_prompt": "What is the capital of {{country}}?",
        "llm_config": { "model": "gpt-4o-mini" }
      }
    }
  }
}

###
# 5b. Invoke — /invoke with URI + parameters inline, zero DB calls
# @name invoke_inline
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs": { "country": "France" },
    "revision": {
      "data": {
        "uri": "agenta:builtin:completion:v0",
        "parameters": {
          "prompt": {
            "system_prompt": "You are an expert in geography",
            "user_prompt": "What is the capital of {{country}}?",
            "llm_config": { "model": "gpt-4o-mini" }
          }
        }
      }
    }
  }
}

###
# 5c. Invoke — /invoke with environment + workflow slug refs (SDK resolves via retrieve)
# @name invoke_by_env
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "references": {
    "environment": { "slug": "{{env_slug}}" },
    "workflow":    { "slug": "{{workflow_slug}}" }
  },
  "data": {
    "inputs": { "country": "France" }
  }
}

###
# BONUS — different prompt: ask for population instead of capital
# @name invoke_population
POST {{services_url}}/completion/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs": { "country": "France" },
    "parameters": {
      "prompt": {
        "system_prompt": "You are an expert in geography",
        "user_prompt": "What is the population of {{country}}?",
        "llm_config": { "model": "gpt-4o-mini" }
      }
    }
  }
}
