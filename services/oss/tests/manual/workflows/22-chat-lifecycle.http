@host = http://localhost
@token = change-me-auth
@api_url = {{host}}/api
@services_url = {{host}}/services

###
# @name create_account
POST {{api_url}}/admin/account
Content-Type: application/json
Authorization: Access {{token}}

###
@authorization = {{create_account.response.body.scopes[0].credentials}}

###
# 0. Fetch catalog
# @name fetch_catalog
GET {{api_url}}/preview/workflows/catalog/templates/
Authorization: {{authorization}}

###
# 1. Inspect the chat template (schema + uri)
# @name get_template
GET {{api_url}}/preview/workflows/catalog/templates/chat
Authorization: {{authorization}}

###
# 2. Create workflow — artifact + variant + committed revision in one shot
# @name create_workflow
POST {{api_url}}/preview/simple/workflows/
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow": {
    "slug": "test-chat-manual",
    "name": "test-chat-manual",
    "flags": {
      "is_application": true,
      "is_chat": true
    },
    "data": {
      "uri": "agenta:builtin:chat:v0",
      "parameters": {
        "prompt": {
          "messages": [
            {
              "role": "system",
              "content": "You are an expert in geography. Keep answers concise."
            }
          ],
          "llm_config": {
            "model": "gpt-4o-mini"
          }
        }
      }
    }
  }
}

###
@workflow_slug = {{create_workflow.response.body.workflow.slug}}
@revision_id   = {{create_workflow.response.body.workflow.revision_id}}
@workflow_url  = {{create_workflow.response.body.workflow.data.url}}

###
# 3. Query environments — find the default one
# @name query_environments
POST {{api_url}}/preview/environments/query
Content-Type: application/json
Authorization: {{authorization}}

{}

###
@environment_id   = {{query_environments.response.body.environments[0].id}}
@environment_slug = {{query_environments.response.body.environments[0].slug}}

###
# 4. Deploy revision to environment
# @name deploy
POST {{api_url}}/preview/workflows/revisions/deploy
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow_revision_ref": { "id": "{{revision_id}}" },
  "environment_ref":       { "id": "{{environment_id}}" }
}

###
# 5a. Invoke — direct service mount
# NOTE: requires a valid LLM API key configured in Agenta vault
# @name invoke_direct
POST {{services_url}}/builtin/chat/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs": {
      "context": "Use factual geography knowledge only."
    },
    "messages": [
      {
        "role": "user",
        "content": "What is the capital of France?"
      }
    ],
    "parameters": {
      "prompt": {
        "messages": [
          {
            "role": "system",
            "content": "You are an expert in geography. Keep answers concise."
          }
        ],
        "llm_config": {
          "model": "gpt-4o-mini"
        }
      }
    }
  }
}

###
# 5b. Invoke — generic dispatcher with inline revision (URI + params)
# @name invoke_inline
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs": {
      "context": "Use factual geography knowledge only."
    },
    "messages": [
      {
        "role": "user",
        "content": "What is the capital of Germany?"
      }
    ],
    "revision": {
      "data": {
        "uri": "agenta:builtin:chat:v0",
        "parameters": {
          "prompt": {
            "messages": [
              {
                "role": "system",
                "content": "You are an expert in geography. Keep answers concise."
              }
            ],
            "llm_config": {
              "model": "gpt-4o-mini"
            }
          }
        }
      }
    }
  }
}

###
# 5c. Invoke — generic dispatcher with environment refs + selector key
# @name invoke_by_env
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "references": {
    "environment": { "slug": "{{environment_slug}}" }
  },
  "selector": {
    "key": "{{workflow_slug}}.revision"
  },
  "data": {
    "inputs": {
      "context": "Use factual geography knowledge only."
    },
    "messages": [
      {
        "role": "user",
        "content": "What is the capital of Italy?"
      }
    ]
  }
}
