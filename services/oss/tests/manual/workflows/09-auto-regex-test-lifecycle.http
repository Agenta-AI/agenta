@host = http://localhost
@token = change-me-auth
@api_url = {{host}}/api
@services_url = {{host}}/services

###
# @name create_account
POST {{api_url}}/admin/account
Content-Type: application/json
Authorization: Access {{token}}

###
@authorization = {{create_account.response.body.scopes[0].credentials}}

###
# 0. Fetch catalog
# @name fetch_catalog
GET {{api_url}}/evaluators/catalog/templates/
Authorization: {{authorization}}

###
# 1. Inspect the auto_regex_test template (schema + uri)
# @name get_template
GET {{api_url}}/evaluators/catalog/templates/auto_regex_test
Authorization: {{authorization}}

###
# 2. Create workflow — artifact + variant + committed revision in one shot
# @name create_workflow
POST {{api_url}}/simple/workflows/
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow": {
    "slug": "test-auto-regex-test-manual",
    "name": "test-auto-regex-test-manual",
    "flags": {
      "is_evaluator": true
    },
    "data": {
      "uri": "agenta:builtin:auto_regex_test:v0",
      "parameters": {
        "regex_pattern": "^Paris",
        "case_sensitive": true,
        "regex_should_match": true
      }
    }
  }
}

###
@workflow_slug = {{create_workflow.response.body.workflow.slug}}
@revision_id   = {{create_workflow.response.body.workflow.revision_id}}
@workflow_url  = {{create_workflow.response.body.workflow.data.url}}

###
# 3. Query environments — find the default one
# @name query_environments
POST {{api_url}}/environments/query
Content-Type: application/json
Authorization: {{authorization}}

{}

###
@environment_id   = {{query_environments.response.body.environments[0].id}}
@environment_slug = {{query_environments.response.body.environments[0].slug}}

###
# 4. Deploy revision to environment
# @name deploy
POST {{api_url}}/workflows/revisions/deploy
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow_revision_ref": { "id": "{{revision_id}}" },
  "environment_ref":       { "id": "{{environment_id}}" }
}

###
# 4b. Check environment revision — verify data.references contains the deployed key
# @name check_env_revision
POST {{api_url}}/environments/revisions/retrieve
Content-Type: application/json
Authorization: {{authorization}}

{
  "environment_ref": { "id": "{{environment_id}}" }
}

###
# 5a. Invoke — direct service mount, no dispatcher
# @name inspect_direct
POST {{services_url}}/auto_regex_test/v0/inspect
Content-Type: application/json
Authorization: {{authorization}}

{}

###
# 5a. Invoke — direct service mount, no dispatcher
# @name invoke_direct
POST {{services_url}}/auto_regex_test/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     {},
    "outputs":    "Paris is the capital of France",
    "parameters": {
      "regex_pattern": "^Paris",
      "case_sensitive": true,
      "regex_should_match": true
    }
  }
}

###
# 5b. Invoke — /invoke with URI + parameters inline, zero DB calls
# @name inspect_inline
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:auto_regex_test:v0",
      "parameters": {
        "regex_pattern": "^Paris",
        "case_sensitive": true,
        "regex_should_match": true
      }
    }
  }
}
###
# 5b. Invoke — /invoke with URI + parameters inline, zero DB calls
# @name invoke_inline
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital of France",
    "revision": {
      "data": {
        "uri": "agenta:builtin:auto_regex_test:v0",
        "parameters": {
          "regex_pattern": "^Paris",
          "case_sensitive": true,
          "regex_should_match": true
        }
      }
    }
  }
}

###
# 5c. Invoke — /invoke with env ref + selector key (SDK resolves via retrieve)
# @name inspect_by_env
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "references": {
    "environment": {
      "slug": "{{environment_slug}}"
    }
  },
  "selector": {
    "key": "{{workflow_slug}}.revision"
  }
}
###
# 5c. Invoke — /invoke with env ref + selector key (SDK resolves via retrieve)
# @name invoke_by_env
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "references": {
    "environment": { "slug": "{{environment_slug}}" }
  },
  "selector": {
    "key": "{{workflow_slug}}.revision"
  },
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital of France"
  }
}

###
# 5d. Invoke — via data.url inferred from URI (full URL, no dispatcher)
# @name inspect_by_url
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:auto_regex_test:v0",
      "parameters": {
        "regex_pattern": "^Paris",
        "case_sensitive": true,
        "regex_should_match": true
      }
    }
  }
}
###
# 5d. Invoke — via data.url inferred from URI (full URL, no dispatcher)
# @name invoke_by_url
POST {{workflow_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     {},
    "outputs":    "Paris is the capital of France",
    "parameters": {
      "regex_pattern": "^Paris",
      "case_sensitive": true,
      "regex_should_match": true
    }
  }
}

###
# BONUS — regex does not match: expect success=false
# @name inspect_mismatch
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:auto_regex_test:v0",
      "parameters": {
        "regex_pattern": "^Paris",
        "case_sensitive": true,
        "regex_should_match": true
      }
    }
  }
}
###
# BONUS — regex does not match: expect success=false
# @name invoke_mismatch
POST {{services_url}}/auto_regex_test/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     {},
    "outputs":    "The capital of France is Paris",
    "parameters": {
      "regex_pattern": "^Paris",
      "case_sensitive": true,
      "regex_should_match": true
    }
  }
}

###
# BONUS2 — regex_should_match=false: passing when regex does NOT match the output
# @name inspect_should_not_match
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:auto_regex_test:v0",
      "parameters": {
        "regex_pattern": "^Berlin",
        "case_sensitive": true,
        "regex_should_match": false
      }
    }
  }
}
###
# BONUS2 — regex_should_match=false: passing when regex does NOT match the output
# @name invoke_should_not_match
POST {{services_url}}/auto_regex_test/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     {},
    "outputs":    "The capital of France is Paris",
    "parameters": {
      "regex_pattern": "^Berlin",
      "case_sensitive": true,
      "regex_should_match": false
    }
  }
}
