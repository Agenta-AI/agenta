###
# text/contains — multiple substrings, match=any (at least one present)
# @name inspect_text_contains_any
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "m1",
            "mode": "text",
            "match": "contains",
            "target": "$.outputs",
            "references": [
              "Paris",
              "Berlin",
              "Rome"
            ],
            "contains": "any"
          }
        ]
      }
    }
  }
}
