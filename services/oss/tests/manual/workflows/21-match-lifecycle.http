###
# json/exact — deep equality of two JSON objects
# @name inspect_json_exact_success
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "m1",
            "mode": "json",
            "match": "exact",
            "target": "$.outputs",
            "reference": "$.inputs.expected"
          }
        ]
      }
    }
  }
}
###
# json/exact — deep equality of two JSON objects
# @name json_exact_success
POST {{services_url}}/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "expected": "{\"city\": \"Paris\"}" },
    "outputs": "{\"city\": \"Paris\"}",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "mode": "json",
          "match": "exact",
          "target": "$.outputs",
          "reference": "$.inputs.expected"
        }
      ]
    }
  }
}

###
# json/diff — field-by-field comparison, default options (diff=full)
# identical JSON → expect score=1.0
# @name inspect_json_overlap_identical
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "m1",
            "mode": "json",
            "match": "diff",
            "target": "$.outputs",
            "reference": "$.inputs.correct",
            "threshold": 0.8
          }
        ]
      }
    }
  }
}
###
# json/diff — field-by-field comparison, default options (diff=full)
# identical JSON → expect score=1.0
# @name json_overlap_identical
POST {{services_url}}/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
