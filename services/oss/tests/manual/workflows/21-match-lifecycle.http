@host = http://localhost
@token = change-me-auth
@api_url = {{host}}/api
@services_url = {{host}}/services

###
# @name create_account
POST {{api_url}}/admin/account
Content-Type: application/json
Authorization: Access {{token}}

###
@authorization = {{create_account.response.body.scopes[0].credentials}}

###
# ============================================================
# match:v0 — Generic rule-based matcher
#
# Supports two kinds:   text | json
# Supports eight modes: valid | exact | starts_with | ends_with |
#                       contains | regex | similarity | overlap(json only)
# Path formats:         JSONPath ($.outputs) | JSON Pointer (/outputs)
# Reference formats:    literal value | JSONPath ref | JSON Pointer ref
# Aggregation:          all (AND) | any (OR) | weighted (threshold-gated)
# Similarity distances: jaccard | levenshtein | cosine (cosine requires LLM)
# ============================================================

###
# 0. Fetch catalog
# @name fetch_catalog
GET {{api_url}}/preview/evaluators/catalog/templates/
Authorization: {{authorization}}

###
# 1. Inspect the match template (schema + uri)
# @name get_template
GET {{api_url}}/preview/evaluators/catalog/templates/match
Authorization: {{authorization}}

###
# ============================================================
# 2. Lifecycle setup — create a minimal match workflow for env-based tests
# @name create_workflow
POST {{api_url}}/preview/simple/workflows/
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow": {
    "slug": "test-match-manual",
    "name": "test-match-manual",
    "flags": { "is_evaluator": true },
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "exact_output",
            "kind": "text",
            "mode": "regex",
            "path": "$.outputs",
            "reference": "^Paris"
          }
        ]
      }
    }
  }
}

###
@workflow_slug = {{create_workflow.response.body.workflow.slug}}
@revision_id   = {{create_workflow.response.body.workflow.revision_id}}
@workflow_url  = {{create_workflow.response.body.workflow.data.url}}

###
# 3. Query environments — find the default one
# @name query_environments
POST {{api_url}}/preview/environments/query
Content-Type: application/json
Authorization: {{authorization}}

{}

###
@environment_id   = {{query_environments.response.body.environments[0].id}}
@environment_slug = {{query_environments.response.body.environments[0].slug}}

###
# 4. Deploy revision to environment
# @name deploy
POST {{api_url}}/preview/workflows/revisions/deploy
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow_revision_ref": { "id": "{{revision_id}}" },
  "environment_ref":       { "id": "{{environment_id}}" }
}

###
# 4b. Check environment revision
# @name check_env_revision
POST {{api_url}}/preview/environments/revisions/retrieve
Content-Type: application/json
Authorization: {{authorization}}

{
  "environment_ref": { "id": "{{environment_id}}" }
}

###
# ============================================================
# INVOKE MODES — via env ref (uses deployed workflow above)
# ============================================================

###
# Invoke — /invoke with env ref + selector key (deployed config)
# @name invoke_by_env
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "references": {
    "environment": { "slug": "{{environment_slug}}" }
  },
  "selector": {
    "key": "{{workflow_slug}}.revision"
  },
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital"
  }
}

###
# Invoke — via data.url (full URL, no dispatcher)
# @name invoke_by_url
POST {{workflow_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "text", "mode": "regex", "path": "$.outputs", "reference": "^Paris" }
      ]
    }
  }
}

###
# ============================================================
# KIND: text — all modes (inline invocations, no DB lookup)
# ============================================================

###
# text/valid — output is a non-empty string → success=true
# @name text_valid_success
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "text", "mode": "valid", "path": "$.outputs" }
      ]
    }
  }
}

###
# text/exact — anchored equality check
# @name text_exact_success
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "text", "mode": "exact", "path": "$.outputs", "reference": "Paris" }
      ]
    }
  }
}

###
# text/exact — mismatch → success=false
# @name text_exact_failure
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "text", "mode": "exact", "path": "$.outputs", "reference": "London" }
      ]
    }
  }
}

###
# text/starts_with — prefix check
# @name text_starts_with_success
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital of France",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "text", "mode": "starts_with", "path": "$.outputs", "reference": "Paris" }
      ]
    }
  }
}

###
# text/ends_with — suffix check
# @name text_ends_with_success
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital of France",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "text", "mode": "ends_with", "path": "$.outputs", "reference": "France" }
      ]
    }
  }
}

###
# text/contains — single substring check
# @name text_contains_single
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital of France",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "capital" }
      ]
    }
  }
}

###
# text/contains — multiple substrings, match=any (at least one present)
# @name text_contains_any
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital of France",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "text",
          "mode": "contains",
          "path": "$.outputs",
          "references": ["Paris", "Berlin", "Rome"],
          "match": "any"
        }
      ]
    }
  }
}

###
# text/contains — multiple substrings, match=all (all must be present)
# @name text_contains_all
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital of France",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "text",
          "mode": "contains",
          "path": "$.outputs",
          "references": ["Paris", "France"],
          "match": "all"
        }
      ]
    }
  }
}

###
# text/regex — anchored pattern match
# @name text_regex_anchored
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "text", "mode": "regex", "path": "$.outputs", "reference": "^Paris" }
      ]
    }
  }
}

###
# text/regex — substring pattern, case_sensitive=false
# @name text_regex_case_insensitive
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "PARIS is the capital",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "text",
          "mode": "regex",
          "path": "$.outputs",
          "reference": "paris",
          "case_sensitive": false
        }
      ]
    }
  }
}

###
# text/similarity — levenshtein distance metric
# @name text_similarity_levenshtein
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "text",
          "mode": "similarity",
          "path": "$.outputs",
          "reference": "Paris",
          "distance": "levenshtein",
          "threshold": 0.8
        }
      ]
    }
  }
}

###
# text/similarity — jaccard distance metric
# @name text_similarity_jaccard
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "text",
          "mode": "similarity",
          "path": "$.outputs",
          "reference": "Paris is the capital of France",
          "distance": "jaccard",
          "threshold": 0.5
        }
      ]
    }
  }
}

###
# ============================================================
# PATH VARIANTS — JSONPath vs JSON Pointer vs dot notation
# ============================================================

###
# Path: JSONPath to nested input field (reference resolved from request)
# @name path_jsonpath_nested_input
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "expected": "Paris" },
    "outputs": "Paris",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "text",
          "mode": "exact",
          "path": "$.outputs",
          "reference": "$.inputs.expected"
        }
      ]
    }
  }
}

###
# Path: JSON Pointer (/outputs)
# @name path_json_pointer
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "text", "mode": "regex", "path": "/outputs", "reference": "^Paris" }
      ]
    }
  }
}

###
# ============================================================
# KIND: json — modes valid, exact, overlap
# ============================================================

###
# json/valid — output is parseable JSON → success=true
# @name json_valid_success
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "{\"city\": \"Paris\"}",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "json", "mode": "valid", "path": "$.outputs" }
      ]
    }
  }
}

###
# json/valid — invalid JSON → success=false
# @name json_valid_failure
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "not json",
    "parameters": {
      "matchers": [
        { "key": "m1", "kind": "json", "mode": "valid", "path": "$.outputs" }
      ]
    }
  }
}

###
# json/exact — deep equality of two JSON objects
# @name json_exact_success
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "expected": "{\"city\": \"Paris\"}" },
    "outputs": "{\"city\": \"Paris\"}",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "json",
          "mode": "exact",
          "path": "$.outputs",
          "reference": "$.inputs.expected"
        }
      ]
    }
  }
}

###
# json/overlap — field-by-field comparison, default options
# identical JSON → expect score=1.0
# @name json_overlap_identical
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "correct": "{\"city\": \"Paris\", \"country\": \"France\"}" },
    "outputs": "{\"city\": \"Paris\", \"country\": \"France\"}",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "json",
          "mode": "overlap",
          "path": "$.outputs",
          "reference": "$.inputs.correct",
          "threshold": 0.8
        }
      ]
    }
  }
}

###
# json/overlap — partial match (one field correct, one wrong)
# Expect score=0.5, success=false (threshold=0.8)
# @name json_overlap_partial
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "correct": "{\"city\": \"Paris\", \"country\": \"France\"}" },
    "outputs": "{\"city\": \"Paris\", \"country\": \"Germany\"}",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "json",
          "mode": "overlap",
          "path": "$.outputs",
          "reference": "$.inputs.correct",
          "threshold": 0.8
        }
      ]
    }
  }
}

###
# json/overlap — use_schema_only=true: compare field types, not values
# Both have "city" as string and "population" as number → score=1.0
# @name json_overlap_schema_only
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "correct": "{\"city\": \"Paris\", \"population\": 2161000}" },
    "outputs": "{\"city\": \"Berlin\", \"population\": 3677000}",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "json",
          "mode": "overlap",
          "path": "$.outputs",
          "reference": "$.inputs.correct",
          "use_schema_only": true,
          "threshold": 0.9
        }
      ]
    }
  }
}

###
# json/overlap — include_unexpected_keys=true: penalize extra keys in output
# Output has an extra "region" key not in reference → score penalized
# @name json_overlap_unexpected_keys
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "correct": "{\"city\": \"Paris\"}" },
    "outputs": "{\"city\": \"Paris\", \"region\": \"Ile-de-France\"}",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "kind": "json",
          "mode": "overlap",
          "path": "$.outputs",
          "reference": "$.inputs.correct",
          "include_unexpected_keys": true,
          "threshold": 0.8
        }
      ]
    }
  }
}

###
# ============================================================
# AGGREGATION STRATEGIES
# ============================================================

###
# all — AND logic: both matchers must succeed
# city=Paris (passes) AND country=France (passes) → aggregate success=true
# @name aggregate_all_success
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital of France",
    "parameters": {
      "matchers": [
        {
          "key": "root",
          "kind": "text",
          "mode": "valid",
          "path": "$.outputs",
          "aggregate": "all",
          "matchers": [
            { "key": "has_paris", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "Paris" },
            { "key": "has_france", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "France" }
          ]
        }
      ]
    }
  }
}

###
# all — AND logic: one fails → aggregate success=false
# @name aggregate_all_failure
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is a great city",
    "parameters": {
      "matchers": [
        {
          "key": "root",
          "kind": "text",
          "mode": "valid",
          "path": "$.outputs",
          "aggregate": "all",
          "matchers": [
            { "key": "has_paris", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "Paris" },
            { "key": "has_france", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "France" }
          ]
        }
      ]
    }
  }
}

###
# any — OR logic: at least one must succeed
# has "Paris" (passes), doesn't have "Berlin" (fails) → aggregate success=true
# @name aggregate_any_success
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital",
    "parameters": {
      "matchers": [
        {
          "key": "root",
          "kind": "text",
          "mode": "valid",
          "path": "$.outputs",
          "aggregate": "any",
          "matchers": [
            { "key": "has_paris", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "Paris" },
            { "key": "has_berlin", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "Berlin" }
          ]
        }
      ]
    }
  }
}

###
# weighted — weighted average with threshold
# m1 passes (1.0, weight=2), m2 fails (0.0, weight=1) → score=0.67, threshold=0.5 → success=true
# @name aggregate_weighted_success
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital",
    "parameters": {
      "matchers": [
        {
          "key": "root",
          "kind": "text",
          "mode": "valid",
          "path": "$.outputs",
          "aggregate": "weighted",
          "threshold": 0.5,
          "matchers": [
            { "key": "has_paris", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "Paris", "weight": 2.0 },
            { "key": "has_france", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "France", "weight": 1.0 }
          ]
        }
      ]
    }
  }
}

###
# weighted — score below threshold → success=false
# m1 fails (0.0, weight=1), m2 fails (0.0, weight=1) → score=0.0, threshold=0.5 → success=false
# @name aggregate_weighted_failure
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Berlin is the capital",
    "parameters": {
      "matchers": [
        {
          "key": "root",
          "kind": "text",
          "mode": "valid",
          "path": "$.outputs",
          "aggregate": "weighted",
          "threshold": 0.5,
          "matchers": [
            { "key": "has_paris", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "Paris", "weight": 1.0 },
            { "key": "has_france", "kind": "text", "mode": "contains", "path": "$.outputs", "reference": "France", "weight": 1.0 }
          ]
        }
      ]
    }
  }
}

###
# ============================================================
# MULTI-MATCHER top-level — multiple independent matchers
# ============================================================

###
# Two independent matchers → two results in response.results[]
# @name multi_top_level_matchers
POST {{services_url}}/builtin/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "expected": "Paris" },
    "outputs": "Paris is the capital of France",
    "parameters": {
      "matchers": [
        { "key": "exact_check",   "kind": "text", "mode": "exact",    "path": "$.outputs",       "reference": "$.inputs.expected" },
        { "key": "contains_check","kind": "text", "mode": "contains", "path": "$.outputs",       "reference": "Paris" },
        { "key": "ends_check",    "kind": "text", "mode": "ends_with","path": "$.outputs",       "reference": "France" }
      ]
    }
  }
}

###
# ============================================================
# INVOKE via dispatcher (inline revision) — covers all path/kind combos
# ============================================================

###
# Invoke inline — text/regex via dispatcher
# @name invoke_inline_text_regex
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital",
    "revision": {
      "data": {
        "uri": "agenta:builtin:match:v0",
        "parameters": {
          "matchers": [
            { "key": "m1", "kind": "text", "mode": "regex", "path": "$.outputs", "reference": "^Paris" }
          ]
        }
      }
    }
  }
}

###
# Invoke inline — json/overlap via dispatcher
# @name invoke_inline_json_overlap
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "correct": "{\"city\": \"Paris\"}" },
    "outputs": "{\"city\": \"Paris\"}",
    "revision": {
      "data": {
        "uri": "agenta:builtin:match:v0",
        "parameters": {
          "matchers": [
            {
              "key": "m1",
              "kind": "json",
              "mode": "overlap",
              "path": "$.outputs",
              "reference": "$.inputs.correct",
              "threshold": 0.8
            }
          ]
        }
      }
    }
  }
}
