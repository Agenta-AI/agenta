@host = http://localhost
@token = change-me-auth
@api_url = {{host}}/api
@services_url = {{host}}/services

###
# @name create_account
POST {{api_url}}/admin/account
Content-Type: application/json
Authorization: Access {{token}}

###
@authorization = {{create_account.response.body.scopes[0].credentials}}

###
# ============================================================
# match:v0 — Generic rule-based matcher
#
# Supports two modes:   text | json
# Supports eight match: valid | exact | starts_with | ends_with |
#                       contains | regex | similarity | diff(json only)
# Target formats:       JSONPath ($.outputs) | JSON Pointer (/outputs)
# Reference formats:    literal value | JSONPath ref | JSON Pointer ref
# Aggregation:          all (AND) | any (OR) | weighted (threshold-gated)
# Similarity metrics:   jaccard | levenshtein | cosine (cosine requires LLM)
# Diff modes:           full (default) | schema (type-only) | strict (penalise extra keys)
# ============================================================

###
# 0. Fetch catalog
# @name fetch_catalog
GET {{api_url}}/preview/evaluators/catalog/templates/
Authorization: {{authorization}}

###
# 1. Inspect the match template (schema + uri)
# @name get_template
GET {{api_url}}/preview/evaluators/catalog/templates/match
Authorization: {{authorization}}

###
# ============================================================
# 2. Lifecycle setup — create a minimal match workflow for env-based tests
# @name create_workflow
POST {{api_url}}/preview/simple/workflows/
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow": {
    "slug": "test-match-manual",
    "name": "test-match-manual",
    "flags": { "is_evaluator": true },
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "exact_output",
            "mode": "text",
            "match": "regex",
            "target": "$.outputs",
            "reference": "^Paris"
          }
        ]
      }
    }
  }
}

###
@workflow_slug = {{create_workflow.response.body.workflow.slug}}
@revision_id   = {{create_workflow.response.body.workflow.revision_id}}
@workflow_url  = {{create_workflow.response.body.workflow.data.url}}

###
# 3. Query environments — find the default one
# @name query_environments
POST {{api_url}}/preview/environments/query
Content-Type: application/json
Authorization: {{authorization}}

{}

###
@environment_id   = {{query_environments.response.body.environments[0].id}}
@environment_slug = {{query_environments.response.body.environments[0].slug}}

###
# 4. Deploy revision to environment
# @name deploy
POST {{api_url}}/preview/workflows/revisions/deploy
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow_revision_ref": { "id": "{{revision_id}}" },
  "environment_ref":       { "id": "{{environment_id}}" }
}

###
# 4b. Check environment revision
# @name check_env_revision
POST {{api_url}}/preview/environments/revisions/retrieve
Content-Type: application/json
Authorization: {{authorization}}

{
  "environment_ref": { "id": "{{environment_id}}" }
}

###
# ============================================================
# INVOKE MODES — via env ref (uses deployed workflow above)
# ============================================================

###
# Invoke — /invoke with env ref + selector key (deployed config)
# @name inspect_by_env
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "references": {
    "environment": {
      "slug": "{{environment_slug}}"
    }
  },
  "selector": {
    "key": "{{workflow_slug}}.revision"
  }
}
###
# Invoke — /invoke with env ref + selector key (deployed config)
# @name invoke_by_env
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "references": {
    "environment": { "slug": "{{environment_slug}}" }
  },
  "selector": {
    "key": "{{workflow_slug}}.revision"
  },
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital"
  }
}

###
# Invoke — via data.url (full URL, no dispatcher)
# @name inspect_by_url
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "m1",
            "mode": "text",
            "match": "regex",
            "target": "$.outputs",
            "reference": "^Paris"
          }
        ]
      }
    }
  }
}
###
# Invoke — via data.url (full URL, no dispatcher)
# @name invoke_by_url
POST {{workflow_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris is the capital",
    "parameters": {
      "matchers": [
        { "key": "m1", "mode": "text", "match": "regex", "target": "$.outputs", "reference": "^Paris" }
      ]
    }
  }
}

###
# ============================================================
# MODE: text — all match values (inline invocations, no DB lookup)
# ============================================================

###
# text/valid — output is a non-empty string → success=true
# @name inspect_text_valid_success
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "m1",
            "mode": "text",
            "match": "valid",
            "target": "$.outputs"
          }
        ]
      }
    }
  }
}
