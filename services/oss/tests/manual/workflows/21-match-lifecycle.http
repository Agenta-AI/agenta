Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "m1",
            "mode": "json",
            "match": "diff",
            "target": "$.outputs",
            "reference": "$.inputs.correct",
            "diff": "strict",
            "threshold": 0.8
          }
        ]
      }
    }
  }
}
###
# json/diff — diff="strict": penalize extra keys in output
