###
# score=weighted, success=threshold — weighted mean >= threshold → success=true
# has_paris (1.0, weight=2), has_france (0.0, weight=1) → score=0.67, threshold=0.5 → success=true
# @name inspect_aggregate_weighted_threshold_success
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "root",
            "mode": "text",
            "match": "valid",
            "target": "$.outputs",
            "score": "weighted",
            "success": "threshold",
            "threshold": 0.5,
            "matchers": [
              {
                "key": "has_paris",
                "mode": "text",
                "match": "contains",
                "target": "$.outputs",
                "reference": "Paris",
                "weight": 2.0
              },
              {
                "key": "has_france",
                "mode": "text",
                "match": "contains",
                "target": "$.outputs",
                "reference": "France",
                "weight": 1.0
              }
            ]
          }
        ]
      }
    }
  }
}
