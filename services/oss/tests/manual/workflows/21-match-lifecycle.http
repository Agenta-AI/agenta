###
# ============================================================
# MULTI-MATCHER top-level — multiple independent matchers
# ============================================================

###
# Two independent matchers → two results in response.results[]
# @name inspect_multi_top_level_matchers
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "exact_check",
            "mode": "text",
            "match": "exact",
            "target": "$.outputs",
            "reference": "$.inputs.expected"
          },
          {
            "key": "contains_check",
            "mode": "text",
            "match": "contains",
            "target": "$.outputs",
            "reference": "Paris"
          },
          {
            "key": "ends_check",
            "mode": "text",
            "match": "ends_with",
            "target": "$.outputs",
            "reference": "France"
          }
        ]
      }
    }
  }
}
###
# Two independent matchers → two results in response.results[]
# @name multi_top_level_matchers
POST {{services_url}}/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "expected": "Paris" },
    "outputs": "Paris is the capital of France",
    "parameters": {
      "matchers": [
        { "key": "exact_check",   "mode": "text", "match": "exact",    "target": "$.outputs",       "reference": "$.inputs.expected" },
        { "key": "contains_check","mode": "text", "match": "contains", "target": "$.outputs",       "reference": "Paris" },
        { "key": "ends_check",    "mode": "text", "match": "ends_with","target": "$.outputs",       "reference": "France" }
      ]
    }
  }
}

