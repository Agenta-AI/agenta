###
# ============================================================
# TARGET VARIANTS — JSONPath vs JSON Pointer vs dot notation
# ============================================================

###
# Path: JSONPath to nested input field (reference resolved from request)
# @name inspect_path_jsonpath_nested_input
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "m1",
            "mode": "text",
            "match": "exact",
            "target": "$.outputs",
            "reference": "$.inputs.expected"
          }
        ]
      }
    }
  }
}
###
# Path: JSONPath to nested input field (reference resolved from request)
# @name path_jsonpath_nested_input
POST {{services_url}}/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "expected": "Paris" },
    "outputs": "Paris",
    "parameters": {
      "matchers": [
        {
          "key": "m1",
          "mode": "text",
          "match": "exact",
          "target": "$.outputs",
          "reference": "$.inputs.expected"
        }
      ]
    }
  }
}

###
# Path: JSON Pointer (/outputs)
# @name inspect_path_json_pointer
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "m1",
            "mode": "text",
            "match": "regex",
            "target": "/outputs",
            "reference": "^Paris"
          }
        ]
      }
    }
  }
}
###
# Path: JSON Pointer (/outputs)
# @name path_json_pointer
POST {{services_url}}/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "Paris",
    "parameters": {
      "matchers": [
        { "key": "m1", "mode": "text", "match": "regex", "target": "/outputs", "reference": "^Paris" }
      ]
    }
  }
}

###
# ============================================================
# MODE: json — match values valid, exact, diff
# ============================================================

###
# json/valid — output is parseable JSON → success=true
# @name inspect_json_valid_success
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "m1",
            "mode": "json",
            "match": "valid",
            "target": "$.outputs"
          }
        ]
      }
    }
  }
}
###
# json/valid — output is parseable JSON → success=true
# @name json_valid_success
POST {{services_url}}/match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  {},
    "outputs": "{\"city\": \"Paris\"}",
    "parameters": {
      "matchers": [
        { "key": "m1", "mode": "json", "match": "valid", "target": "$.outputs" }
      ]
    }
  }
}

