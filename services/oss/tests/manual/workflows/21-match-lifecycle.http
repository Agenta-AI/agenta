          "threshold": 0.8
        }
      ]
    }
  }
}

###
# ============================================================
# AGGREGATION — score: weighted|min|max  /  success: all|any|threshold
# ============================================================

###
# success=all — all children must pass
# has_paris (passes) AND has_france (passes) → success=true, score=1.0
# @name inspect_aggregate_all_success
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:match:v0",
      "parameters": {
        "matchers": [
          {
            "key": "root",
            "mode": "text",
            "match": "valid",
            "target": "$.outputs",
            "success": "all",
            "matchers": [
              {
                "key": "has_paris",
                "mode": "text",
                "match": "contains",
                "target": "$.outputs",
                "reference": "Paris"
              },
              {
                "key": "has_france",
                "mode": "text",
                "match": "contains",
                "target": "$.outputs",
                "reference": "France"
              }
            ]
          }
        ]
      }
    }
  }
}
