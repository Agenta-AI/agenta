@host = http://localhost
@token = change-me-auth
@api_url = {{host}}/api
@services_url = {{host}}/services

###
# @name create_account
POST {{api_url}}/admin/account
Content-Type: application/json
Authorization: Access {{token}}

###
@authorization = {{create_account.response.body.scopes[0].credentials}}

###
# 0. Fetch catalog
# @name fetch_catalog
GET {{api_url}}/evaluators/catalog/templates/
Authorization: {{authorization}}

###
# 1. Inspect the json_multi_field_match template (schema + uri)
# @name get_template
GET {{api_url}}/evaluators/catalog/templates/json_multi_field_match
Authorization: {{authorization}}

###
# 2. Create workflow — artifact + variant + committed revision in one shot
# Compares multiple JSON fields and produces per-field + aggregate scores
# @name create_workflow
POST {{api_url}}/simple/workflows/
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow": {
    "slug": "test-json-multi-field-match-manual",
    "name": "test-json-multi-field-match-manual",
    "flags": {
      "is_evaluator": true
    },
    "data": {
      "uri": "agenta:builtin:json_multi_field_match:v0",
      "parameters": {
        "fields": ["city", "country"],
        "correct_answer_key": "correct_answer"
      }
    }
  }
}

###
@workflow_slug = {{create_workflow.response.body.workflow.slug}}
@revision_id   = {{create_workflow.response.body.workflow.revision_id}}
@workflow_url  = {{create_workflow.response.body.workflow.data.url}}

###
# 3. Query environments — find the default one
# @name query_environments
POST {{api_url}}/environments/query
Content-Type: application/json
Authorization: {{authorization}}

{}

###
@environment_id   = {{query_environments.response.body.environments[0].id}}
@environment_slug = {{query_environments.response.body.environments[0].slug}}

###
# 4. Deploy revision to environment
# @name deploy
POST {{api_url}}/workflows/revisions/deploy
Content-Type: application/json
Authorization: {{authorization}}

{
  "workflow_revision_ref": { "id": "{{revision_id}}" },
  "environment_ref":       { "id": "{{environment_id}}" }
}

###
# 4b. Check environment revision
# @name check_env_revision
POST {{api_url}}/environments/revisions/retrieve
Content-Type: application/json
Authorization: {{authorization}}

{
  "environment_ref": { "id": "{{environment_id}}" }
}

###
# 5a. Invoke — direct service mount, no dispatcher
# both fields match → expect all field scores=1.0, aggregate score=1.0
# @name inspect_direct
POST {{services_url}}/json_multi_field_match/v0/inspect
Content-Type: application/json
Authorization: {{authorization}}

{}

###
# 5a. Invoke — direct service mount, no dispatcher
# both fields match → expect all field scores=1.0, aggregate score=1.0
# @name invoke_direct
POST {{services_url}}/json_multi_field_match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     { "correct_answer": "{\"city\": \"Paris\", \"country\": \"France\"}" },
    "outputs":    "{\"city\": \"Paris\", \"country\": \"France\"}",
    "parameters": { "fields": ["city", "country"], "correct_answer_key": "correct_answer" }
  }
}

###
# 5b. Invoke — /invoke with URI + parameters inline, zero DB calls
# @name inspect_inline
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:json_multi_field_match:v0",
      "parameters": {
        "fields": [
          "city",
          "country"
        ],
        "correct_answer_key": "correct_answer"
      }
    }
  }
}
###
# 5b. Invoke — /invoke with URI + parameters inline, zero DB calls
# @name invoke_inline
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":  { "correct_answer": "{\"city\": \"Paris\", \"country\": \"France\"}" },
    "outputs": "{\"city\": \"Paris\", \"country\": \"France\"}",
    "revision": {
      "data": {
        "uri": "agenta:builtin:json_multi_field_match:v0",
        "parameters": { "fields": ["city", "country"], "correct_answer_key": "correct_answer" }
      }
    }
  }
}

###
# 5c. Invoke — /invoke with env ref + selector key
# @name inspect_by_env
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "references": {
    "environment": {
      "slug": "{{environment_slug}}"
    }
  },
  "selector": {
    "key": "{{workflow_slug}}.revision"
  }
}
###
# 5c. Invoke — /invoke with env ref + selector key
# @name invoke_by_env
POST {{services_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "references": {
    "environment": { "slug": "{{environment_slug}}" }
  },
  "selector": {
    "key": "{{workflow_slug}}.revision"
  },
  "data": {
    "inputs":  { "correct_answer": "{\"city\": \"Paris\", \"country\": \"France\"}" },
    "outputs": "{\"city\": \"Paris\", \"country\": \"France\"}"
  }
}

###
# 5d. Invoke — via data.url inferred from URI (full URL, no dispatcher)
# @name inspect_by_url
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:json_multi_field_match:v0",
      "parameters": {
        "fields": [
          "city",
          "country"
        ],
        "correct_answer_key": "correct_answer"
      }
    }
  }
}
###
# 5d. Invoke — via data.url inferred from URI (full URL, no dispatcher)
# @name invoke_by_url
POST {{workflow_url}}/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     { "correct_answer": "{\"city\": \"Paris\", \"country\": \"France\"}" },
    "outputs":    "{\"city\": \"Paris\", \"country\": \"France\"}",
    "parameters": { "fields": ["city", "country"], "correct_answer_key": "correct_answer" }
  }
}

###
# BONUS — partial match: city correct, country wrong
# Expect per-field: city=1.0, country=0.0 → aggregate score=0.5
# @name inspect_partial_match
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:json_multi_field_match:v0",
      "parameters": {
        "fields": [
          "city",
          "country"
        ],
        "correct_answer_key": "correct_answer"
      }
    }
  }
}
###
# BONUS — partial match: city correct, country wrong
# Expect per-field: city=1.0, country=0.0 → aggregate score=0.5
# @name invoke_partial_match
POST {{services_url}}/json_multi_field_match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     { "correct_answer": "{\"city\": \"Paris\", \"country\": \"France\"}" },
    "outputs":    "{\"city\": \"Paris\", \"country\": \"Germany\"}",
    "parameters": { "fields": ["city", "country"], "correct_answer_key": "correct_answer" }
  }
}

###
# BONUS2 — single field only (subset of fields)
# @name inspect_single_field
POST {{services_url}}/inspect
Content-Type: application/json
Authorization: {{authorization}}

{
  "revision": {
    "data": {
      "uri": "agenta:builtin:json_multi_field_match:v0",
      "parameters": {
        "fields": [
          "city"
        ],
        "correct_answer_key": "correct_answer"
      }
    }
  }
}
###
# BONUS2 — single field only (subset of fields)
# @name invoke_single_field
POST {{services_url}}/json_multi_field_match/v0/invoke
Content-Type: application/json
Authorization: {{authorization}}

{
  "data": {
    "inputs":     { "correct_answer": "{\"city\": \"Paris\"}" },
    "outputs":    "{\"city\": \"Paris\"}",
    "parameters": { "fields": ["city"], "correct_answer_key": "correct_answer" }
  }
}
