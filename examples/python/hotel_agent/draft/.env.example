# Copy to .env and fill in the values you need.
# .env is gitignored at the repo root; .env.example is checked in.

# ===========================================
# LLM provider keys
# ===========================================
# Pydantic-AI / OpenAI Agents SDK read OPENAI_API_KEY from env.
OPENAI_API_KEY=sk-...

# Claude Agent SDK reads ANTHROPIC_API_KEY from env.
ANTHROPIC_API_KEY=sk-ant-...

# ===========================================
# Default model (per-runtime override possible)
# ===========================================
# Pydantic-AI model string. Examples:
#   openai:gpt-4o-mini   anthropic:claude-3-5-sonnet-latest   google:gemini-1.5-flash
LLM_MODEL=openai:gpt-4o-mini

# ===========================================
# Server
# ===========================================
# The runtime is selected per-request via the route: POST /api/chat/{runtime}.
# The "logged-in guest" is selected per-request via the request body
# ({"current_user_id": "guest_sarah"}), driven by the frontend persona switcher.
# No env vars are needed for either; both come from the frontend.

# ===========================================
# Agenta (only used by with_agenta runtimes)
# ===========================================
AGENTA_API_KEY=
AGENTA_HOST=https://cloud.agenta.ai
