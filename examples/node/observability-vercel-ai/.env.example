AGENTA_HOST=https://cloud.agenta.ai
AGENTA_API_KEY=your-agenta-api-key
OPENAI_API_KEY=your-openai-api-key

# Optional Braintrust dual-export. Leave unset to disable.
# BRAINTRUST_API_KEY=sk-...
# BRAINTRUST_OTLP_URL=https://api.braintrust.dev/otel/v1/traces

# Optional Langfuse tri-export. Auth is base64(LANGFUSE_PUBLIC_KEY:LANGFUSE_SECRET_KEY)
# in a Basic header. Leave keys unset to disable.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
