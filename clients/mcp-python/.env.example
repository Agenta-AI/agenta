# Required. This API key carries the Agenta project scope used by every MCP caller.
AGENTA_API_KEY=agenta-api-key

# Cloud examples use https://cloud.agenta.ai/api; the committed spec also lists /api and https://eu.cloud.agenta.ai/api.
# For Docker Compose sibling deployments, use http://api:8000.
# For self-hosted host access, use http://localhost/api.
AGENTA_API_URL=https://cloud.agenta.ai/api

# Confirmed Agenta convention is Authorization: ApiKey <key>.
# Set to bare only for non-standard deployments that accept raw keys.
AGENTA_AUTH_SCHEME=ApiKey

# stdio for desktop clients; streamable-http for hosted/internal deployment.
AGENTA_MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8001
